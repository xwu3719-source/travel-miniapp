/* ══════ 底部导航 ══════ */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: var(--theme-tab-bar-bg, rgba(255,255,255,0.88));
  padding: 8rpx 0 4rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.05);
  z-index: 999;
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 0;
  flex: 1;
  transition: all 0.2s;
}

.tab-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  margin-bottom: 2rpx;
  transition: all 0.25s;
}

.tab-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.62;
  transition: all 0.25s;
}

.tab-text {
  font-size: 20rpx;
  color: #b0b0b0;
  font-weight: 500;
  transition: all 0.25s;
}

.tab-badge {
  position: absolute;
  right: 6rpx;
  top: -4rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
  font-weight: 800;
  box-sizing: border-box;
  box-shadow: 0 4rpx 10rpx rgba(255, 77, 79, 0.28);
}

/* ══════ 选中态 · 浅蓝玻璃渐变 ══════ */
.tab-item.active .tab-icon-wrap {
  background: var(--gradient-trip-soft);
  border: 1rpx solid var(--trip-blue-light);
  box-shadow: 0 7rpx 20rpx var(--theme-shadow), inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.tab-item.active .tab-icon-img {
  opacity: 0.94;
  transform: scale(1.06);
  filter: var(--theme-icon-filter);
}

.tab-item.active .tab-text {
  color: var(--theme-primary);
  font-weight: 700;
}

.tab-item.center .tab-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  margin-top: -36rpx;
  margin-bottom: 0;
  border-radius: 50%;
  background: var(--gradient-trip);
  border: 3rpx solid #fff;
  box-shadow: 0 8rpx 28rpx var(--theme-shadow), 0 2rpx 8rpx var(--theme-shadow);
  box-sizing: border-box;
}
.tab-item.center .tab-icon-img { width: 48rpx; height: 48rpx; opacity: 1; filter: brightness(0) invert(1); }
.tab-item.center .tab-text { margin-top: 1rpx; }
.tab-item.center.active .tab-icon-wrap { transform: translateY(-4rpx) scale(1.05); box-shadow: 0 12rpx 36rpx var(--theme-shadow), 0 4rpx 12rpx var(--theme-shadow); }

.theme-night.tab-bar {
  background: rgba(15, 23, 42, 0.86);
  box-shadow: 0 -2rpx 26rpx rgba(0,0,0,0.22);
}
