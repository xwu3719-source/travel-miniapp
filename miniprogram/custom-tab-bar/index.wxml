<view class="tab-bar safe-bottom {{themeClass}}" style="{{themeStyle}}">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item tab-{{index}} {{item.center ? 'center' : ''}} {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <image class="tab-icon-img" src="{{item.iconPath}}" mode="aspectFit" />
      <view wx:if="{{index === 3 && unreadCount > 0}}" class="tab-badge">{{unreadText}}</view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
