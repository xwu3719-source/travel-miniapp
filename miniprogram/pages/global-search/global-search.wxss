page { height: 100%; background: var(--bg); }
.gs-page { height: 100vh; padding: 20rpx 22rpx 0; box-sizing: border-box; overflow: hidden; }
.gs-search { height: 82rpx; display: flex; align-items: center; gap: 14rpx; padding: 0 22rpx; border-radius: 26rpx; background: rgba(255,255,255,.9); border: 1rpx solid rgba(91,159,245,.13); box-shadow: var(--shadow-sm); }
.gs-search input { flex: 1; height: 100%; min-width: 0; color: var(--text-primary); font-size: 27rpx; }
.gs-clear { width: 28rpx; height: 28rpx; opacity: .55; }
.gs-state { height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #6f8195; font-size: 28rpx; }
.gs-state-icon { width: 74rpx; height: 74rpx; margin-bottom: 22rpx; opacity: .72; }
.gs-state-sub { margin-top: 12rpx; color: #a0adbb; font-size: 23rpx; }
.gs-results { height: calc(100vh - 116rpx); margin-top: 20rpx; }
.gs-section { margin-bottom: 24rpx; padding: 10rpx 20rpx; border-radius: 26rpx; background: rgba(255,255,255,.92); box-shadow: var(--shadow-sm); }
.gs-section-title { padding: 16rpx 4rpx 12rpx; color: #7890aa; font-size: 23rpx; font-weight: 750; }
.gs-row { min-height: 104rpx; display: flex; align-items: center; gap: 16rpx; padding: 12rpx 4rpx; border-top: 1rpx solid rgba(125,185,248,.09); box-sizing: border-box; }
.gs-avatar,.gs-type-icon { width: 68rpx; height: 68rpx; flex-shrink: 0; border-radius: 22rpx; }
.gs-avatar.placeholder,.gs-type-icon { display: flex; align-items: center; justify-content: center; color: #4f88c8; background: #edf6ff; font-size: 27rpx; font-weight: 800; }
.gs-type-icon image { width: 38rpx; height: 38rpx; }
.gs-copy { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 7rpx; }
.gs-title,.gs-sub { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gs-title { color: #263b52; font-size: 27rpx; font-weight: 700; }
.gs-sub { color: #8796a8; font-size: 22rpx; }
.gs-time { max-width: 150rpx; overflow: hidden; color: #a4afbb; font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.gs-arrow { width: 24rpx; height: 24rpx; opacity: .42; }
.gs-safe { height: calc(30rpx + env(safe-area-inset-bottom)); }
