/* 我的 · 个人中心 */

.profile-page {
  padding-bottom: 150rpx;
}

/* ══════ 个人卡片 ══════ */
.profile-card {
  position: relative;
  background: linear-gradient(180deg, var(--card-bg) 0%, var(--trip-blue-soft) 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.profile-card::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 8rpx;
  background: var(--gradient-trip);
}

.pc-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.pc-kicker {
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 700;
}

.pc-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.pc-setting-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: var(--trip-blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pc-setting-img {
  width: 34rpx;
  height: 34rpx;
}

/* 头像 */
.pc-avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.pc-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid var(--card-bg);
  box-shadow: 0 8rpx 24rpx var(--theme-shadow-sm);
}

.pc-avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--gradient-trip-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--theme-primary);
  font-weight: 800;
  border: 6rpx solid var(--card-bg);
  box-shadow: 0 8rpx 24rpx var(--theme-shadow-sm);
}

/* 右侧信息 */
.pc-info {
  flex: 1;
  min-width: 0;
}

.pc-name {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.pc-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.pc-verified {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.pc-worn-badge {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
}

.pc-status-trigger {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.72;
}

.pc-status-trigger.active {
  opacity: 1;
}

.pc-status-trigger:active,
.pc-status-trigger-pressed {
  transform: scale(0.94);
  opacity: 0.82;
}

.pc-status-icon {
  width: 38rpx;
  height: 38rpx;
}

.pc-public-id {
  color: var(--theme-primary);
  font-size: 21rpx;
  font-weight: 700;
}

.pc-id-row {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pc-id-edit {
  color: var(--text-hint);
  font-size: 20rpx;
  padding: 2rpx 8rpx;
}

.id-editor-note {
  margin-top: 14rpx;
  color: var(--text-hint);
  font-size: 22rpx;
  line-height: 1.45;
}

.id-editor-modal .form-input:focus {
  border-color: var(--theme-primary);
  box-shadow: 0 0 0 5rpx var(--theme-shadow-sm);
}

.id-editor-modal .btn-outline {
  background: rgba(255, 255, 255, 0.78);
  color: var(--theme-primary);
  border-color: rgba(var(--theme-primary-rgb), 0.4);
}

.id-editor-modal .btn-primary {
  background: var(--gradient-trip);
  color: #fff;
  box-shadow: 0 7rpx 18rpx var(--theme-shadow);
}

.pc-social-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.pc-social-item {
  display: inline-flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 2rpx 0;
}

.pc-social-num {
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 800;
}

.pc-social-label {
  color: var(--text-hint);
  font-size: 22rpx;
  font-weight: 600;
}

.pc-social-divider {
  width: 2rpx;
  height: 20rpx;
  background: var(--border);
}

.pc-signature {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.4;
  max-width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.pc-signature.empty {
  color: var(--text-hint);
}

.pc-action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.pc-action {
  flex: 1;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.pc-action.primary {
  background: var(--gradient-trip);
  color: #fff;
  box-shadow: 0 8rpx 22rpx var(--theme-shadow);
}

.pc-action.secondary {
  background: var(--bg);
  color: var(--text-secondary);
}

/* ══════ 徽章 ══════ */
.badge-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.badge-count {
  font-size: 22rpx;
  color: var(--text-hint);
  font-weight: 600;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  flex: 0 0 calc((100% - 32rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
  box-sizing: border-box;
}

.badge-item.earned {
  background: linear-gradient(135deg, var(--trip-blue-light), rgba(var(--theme-primary-rgb), 0.08));
  border: 1rpx solid rgba(var(--theme-primary-rgb), 0.2);
}

.badge-item.earned:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.badge-item.wearing {
  border: 2rpx solid var(--theme-primary);
  box-shadow: 0 0 0 4rpx var(--theme-shadow-sm);
}

.badge-item.locked {
  background: #f5f6f9;
  opacity: 0.45;
  filter: grayscale(1);
}

.badge-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.badge-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  min-width: 0;
}

.badge-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.badge-name {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
  text-align: center;
}

.badge-wearing-tag {
  font-size: 16rpx;
  font-weight: 600;
  color: var(--theme-primary);
  background: rgba(var(--theme-primary-rgb), 0.12);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.badge-condition {
  font-size: 18rpx;
  color: var(--text-hint);
  font-weight: 500;
  line-height: 1.2;
  text-align: center;
}

/* ══════ 统计卡片 ══════ */
.overview-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-header.compact {
  padding: 0 0 18rpx;
}

.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 0;
}

.stat-box {
  flex: 1;
  border-radius: 18rpx;
  padding: 22rpx 10rpx;
  text-align: center;
  background: var(--bg);
  color: var(--text-primary);
}

.stat-box:nth-child(1) {
  background: var(--trip-blue-light);
}

.stat-box:nth-child(2) {
  background: var(--trip-blue-soft);
}

.stat-box:nth-child(3) {
  background: rgba(var(--theme-primary-rgb), 0.08);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  font-weight: 600;
}

/* ══════ 旅行档案 ══════ */
.passport-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20rpx 24rpx 12rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.passport-dot {
  background: var(--gradient-teal) !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  background-clip: text !important;
}

.passport-card {
  overflow: hidden;
}

.passport-item {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.passport-item:last-child {
  border-bottom: none;
}

.passport-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.passport-icon-img {
  width: 38rpx;
  height: 38rpx;
}

.pi-moment {
  background: linear-gradient(135deg, rgba(var(--theme-primary-rgb), 0.12), rgba(var(--theme-primary-rgb), 0.04));
  border: 1rpx solid rgba(var(--theme-primary-rgb), 0.28);
  box-shadow: 0 7rpx 18rpx var(--theme-shadow-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.pi-moment .passport-icon-img {
  filter: var(--theme-icon-filter);
}

.pi-packing {
  background: linear-gradient(135deg, rgba(209, 250, 229, 0.9), rgba(236, 253, 245, 0.66));
  border: 1rpx solid rgba(16, 185, 129, 0.30);
  box-shadow: 0 7rpx 18rpx rgba(16, 185, 129, 0.10), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
}

.pi-packing .passport-icon-img {
  filter: brightness(0) saturate(100%) invert(56%) sepia(74%) saturate(428%) hue-rotate(95deg) brightness(95%) contrast(90%);
}

.packing-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 0;
}

.progress-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #10b981;
  background: #d1fae5;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  margin-left: auto;
  margin-right: 8rpx;
}

.passport-copy {
  flex: 1;
  min-width: 0;
}

.passport-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.passport-desc {
  margin-top: 8rpx;
  color: var(--text-hint);
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.passport-arrow {
  color: var(--text-hint);
  font-size: 34rpx;
  font-weight: 300;
}

/* ══════ 资料完整度 ══════ */
.completeness-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.completeness-bar {
  height: 10rpx;
  background: var(--border);
  border-radius: 5rpx;
  overflow: hidden;
}

.completeness-fill {
  height: 100%;
  background: var(--gradient-trip);
  border-radius: 5rpx;
  transition: width 0.6s ease;
}

.completeness-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  line-height: 1.3;
}

/* ══════ 旅行概览 · 副统计 ══════ */
.stats-row-sub {
  margin-top: 12rpx;
}

/* ══════ 旅行足迹 ══════ */
.footprint-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.footprint-count {
  font-size: 22rpx;
  color: var(--text-hint);
  font-weight: 600;
}

.footprint-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.footprint-chip {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--theme-primary);
  background: linear-gradient(135deg, var(--trip-blue-light), rgba(var(--theme-primary-rgb), 0.08));
  border: 1rpx solid rgba(var(--theme-primary-rgb), 0.18);
}

/* ══════ 历史行程 ══════ */
.history-section {
  margin-top: 4rpx;
  padding-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 4rpx 20rpx;
  color: var(--text-primary);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.section-dot {
  font-size: 24rpx;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.toggle-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  transition: transform 0.25s;
  font-weight: 300;
}

.toggle-arrow.open {
  transform: rotate(90deg);
}

.history-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
  border-left: 8rpx solid;
  position: relative;
  overflow: hidden;
}

.history-card:nth-child(5n+1) { border-left-color: #ff6b6b; }
.history-card:nth-child(5n+2) { border-left-color: #0ea5e9; }
.history-card:nth-child(5n+3) { border-left-color: var(--theme-primary); }
.history-card:nth-child(5n+4) { border-left-color: #ec4899; }
.history-card:nth-child(5n+5) { border-left-color: #f59e0b; }

.hc-name {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.hc-meta {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ══════ 行李清单 ══════ */
.packing-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
