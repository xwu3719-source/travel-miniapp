/* 动态页 · 紫韵渐变色 */

.trip-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.trip-chip {
  display: inline-flex;
  padding: 14rpx 26rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: var(--card-bg);
  color: var(--text-secondary);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.trip-chip.active {
  background: var(--gradient-purple);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(168, 85, 247, 0.25);
}

/* 动态卡片 */
.moment-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
}


.mi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mi-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mi-avatar, .mi-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.mi-avatar-placeholder {
  background: linear-gradient(135deg, #f5e0ff, #ecccff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--purple);
  font-weight: 600;
}

.mi-name {
  font-size: 26rpx;
  font-weight: 600;
}

.mi-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.mi-text {
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.mi-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: var(--bg);
}

.mi-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-video {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mi-video-play {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-video-dur {
  position: absolute;
  bottom: 8rpx;
  right: 10rpx;
  font-size: 22rpx;
  color: #a5b4fc;
  background: rgba(0,0,0,0.5);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.mi-location {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.mi-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 互动栏 */
.mi-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--border);
}

.mi-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 10rpx 14rpx;
}

.mi-action-icon {
  font-size: 34rpx;
}

.mi-action-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.mi-action-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e1e2e;
}

.mi-action.liked .mi-action-icon {
  color: var(--rose);
}

.mi-action.favorited .mi-action-icon {
  color: var(--amber);
}

/* 右上角更多按钮 */
.mi-more {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #e5e7eb;
}

.mi-more:active {
  background: #d1d5db;
}

.mi-more-icon {
  font-size: 32rpx;
  color: #374151;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1;
}

/* 管理菜单 */
.mi-menu {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 20;
  overflow: hidden;
  min-width: 220rpx;
}

.mi-menu-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
}

.mi-menu-item:active {
  background: var(--bg);
}

.mi-menu-item.danger {
  color: var(--red);
}

/* 评论区 */
.mi-comments {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.cmt-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cmt-item {
  display: flex;
  gap: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.cmt-body {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.cmt-author {
  color: var(--purple);
  font-weight: 600;
  flex-shrink: 0;
}

.cmt-text {
  color: var(--text-primary);
}

.cmt-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  display: block;
}

.cmt-empty {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 16rpx 0;
}

/* 评论语音 */
.cmt-voice {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.cmt-voice-icon {
  font-size: 24rpx;
}

.cmt-voice-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.cmt-voice-dur {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 评论位置 */
.cmt-location {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--teal);
  padding: 4rpx 10rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 8rpx;
}

.cmt-loc-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 评论输入区 */
.cmt-input-area {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.cmt-media-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cmp-item {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cmp-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.cmp-voice-item {
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.cmp-voice-icon {
  font-size: 28rpx;
}

.cmp-voice-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.cmp-voice-dur {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.cmp-loc-item {
  gap: 4rpx;
  padding: 8rpx 14rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--teal);
}

.cmp-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cmt-input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cmt-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: var(--bg);
  border-radius: 32rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.cmt-tool-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.cmt-tool-icon {
  width: 32rpx;
  height: 32rpx;
}

.cmt-tool-btn.recording {
  background: #fef2f2;
}

/* 录音状态条 */
.recording-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  border: 2rpx solid #fecaca;
  margin-bottom: 12rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: recPulse 0.8s infinite;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.rec-text {
  flex: 1;
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 600;
}

.rec-time {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.rec-stop {
  font-size: 24rpx;
  color: #fff;
  background: #ef4444;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.cmt-send {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--purple);
  padding: 0 12rpx;
  flex-shrink: 0;
}

/* FAB */
.detail-fabs {
  position: fixed;
  right: 40rpx;
  bottom: 240rpx;
  z-index: 99;
}

.detail-fab {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--gradient-purple);
  color: #fff;
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.35);
}
