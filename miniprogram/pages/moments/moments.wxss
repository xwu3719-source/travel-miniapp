/* 动态页 · 紫韵渐变色 */

.page-scroll {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.moments-topbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

/* 动态模式切换 · 融入 topbar */
.feed-toggle {
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
  box-shadow: var(--shadow-sm);
  transition: all 0.18s;
  flex-shrink: 0;
}

.feed-toggle.active {
  color: #fff;
  background: var(--gradient-purple);
  box-shadow: 0 7rpx 18rpx rgba(91,159,245,0.2);
}

.moment-filter-pill {
  flex: 0 1 auto;
  min-width: 180rpx;
  max-width: 420rpx;
  min-width: 0;
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.moment-filter-pill text:first-child {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.moment-filter-pill.active {
  color: var(--purple);
  background: var(--purple-light);
}

.filter-caret {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.42;
  transform: rotate(90deg);
}

.my-space-entry {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: var(--gradient-purple);
  box-shadow: 0 8rpx 22rpx rgba(91,159,245,0.22);
  flex-shrink: 0;
  margin-left: auto;
  box-sizing: border-box;
}

.moment-create-entry {
  height: 66rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: var(--gradient-purple);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
  box-shadow: 0 7rpx 18rpx rgba(91,159,245,0.2);
  box-sizing: border-box;
}

.moment-create-entry image {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

.my-space-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #fff;
  box-sizing: border-box;
}

.my-space-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--purple);
  font-size: 28rpx;
  font-weight: 800;
  background: #fff;
}

.moments-topbar-spacer {
  flex: 1;
}

/* 动态卡片 */
.moment-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
}


.mi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mi-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mi-avatar, .mi-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.mi-avatar-placeholder {
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--purple);
  font-weight: 600;
}

.mi-name {
  font-size: 26rpx;
  font-weight: 600;
}

.mi-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mi-verified-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.mi-badge-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.mi-status-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.mi-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.mi-meta-line {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--text-hint);
  font-size: 22rpx;
}

.mi-trip-badge {
  max-width: 250rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: var(--purple-light);
  color: var(--purple);
  font-size: 20rpx;
  font-weight: 700;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 行程筛选弹层 */
.filter-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 18rpx 18rpx;
  background: rgba(31, 25, 42, 0.16);
  backdrop-filter: blur(10rpx);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  box-sizing: border-box;
}

.filter-panel {
  width: 100%;
  max-height: 68vh;
  padding: 14rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  border: 1rpx solid rgba(255,255,255,0.9);
  border-radius: 34rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 24rpx 80rpx rgba(52, 38, 72, 0.2);
  box-sizing: border-box;
  animation: filterPanelIn 0.22s ease-out;
}

@keyframes filterPanelIn {
  from { transform: translateY(24rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.filter-handle {
  width: 68rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #ded8e8;
}

.filter-header {
  padding: 0 8rpx 18rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.filter-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
}

.filter-subtitle {
  margin-top: 5rpx;
  color: var(--text-hint);
  font-size: 21rpx;
}

.filter-count {
  flex-shrink: 0;
  margin-top: 4rpx;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  color: var(--purple);
  background: var(--purple-light);
  font-size: 20rpx;
  font-weight: 700;
}

.filter-trip-list {
  max-height: 45vh;
  margin-top: 8rpx;
}

.filter-option {
  min-height: 104rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid transparent;
  border-radius: 22rpx;
  background: #f8f7fb;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.filter-option + .filter-option {
  margin-top: 10rpx;
}

.filter-option.active {
  border-color: rgba(91, 159, 245, 0.22);
  background: linear-gradient(135deg, #f3f8ff 0%, #e6f1ff 100%);
  box-shadow: 0 8rpx 22rpx rgba(91,159,245,0.09);
}

.filter-leading {
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  color: #5b9ff5;
  background: linear-gradient(135deg, #edf6ff, #dcecff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.filter-leading.all {
  color: #fff;
  background: var(--gradient-purple);
}

.filter-copy {
  min-width: 0;
  flex: 1;
}

.filter-name {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.filter-desc {
  margin-top: 6rpx;
  color: var(--text-hint);
  font-size: 22rpx;
}

.filter-radio {
  transform: scale(0.82);
  flex-shrink: 0;
}

.mi-text {
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.mi-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: var(--bg);
}

.mi-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-video {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mi-video-play {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-video-dur {
  position: absolute;
  bottom: 8rpx;
  right: 10rpx;
  font-size: 22rpx;
  color: #a5b4fc;
  background: rgba(0,0,0,0.5);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.mi-location {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.mi-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 互动栏 */
.mi-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  padding-top: 14rpx;
}

.mi-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  min-height: var(--icon-touch);
  padding: 8rpx 12rpx;
  box-sizing: border-box;
}

.mi-action-icon {
  font-size: 34rpx;
}

.mi-action-icon-img {
  width: var(--icon-sm);
  height: var(--icon-sm);
  opacity: var(--icon-muted-opacity);
}

.mi-action.liked .mi-action-icon-img,
.mi-action.favorited .mi-action-icon-img { opacity: var(--icon-active-opacity); }

.mi-action-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e1e2e;
}

.mi-action.liked .mi-action-icon {
  color: var(--rose);
}

.mi-action.favorited .mi-action-icon {
  color: var(--amber);
}

/* 右上角更多按钮 */
.mi-more {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #e5e7eb;
}

.mi-more:active {
  background: #d1d5db;
}

.mi-more-icon-img { width: 36rpx; height: 36rpx; opacity: 0.72; }

/* 管理菜单 */
.mi-menu {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 20;
  overflow: hidden;
  min-width: 220rpx;
}

.mi-menu-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
}

.mi-menu-item:active {
  background: var(--bg);
}

.mi-menu-item.danger {
  color: var(--red);
}

/* 评论区 */
.mi-comments {
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.cmt-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cmt-item {
  display: flex;
  gap: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.cmt-body {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.cmt-author {
  color: var(--purple);
  font-weight: 600;
  flex-shrink: 0;
}

.cmt-reply-mark {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.cmt-text {
  color: var(--text-primary);
}

.cmt-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  display: block;
}

.cmt-empty {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 16rpx 0;
}

/* 评论语音 */
.cmt-voice {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.cmt-voice-icon {
  font-size: 24rpx;
}

.cmt-voice-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.cmt-voice.voice-playing {
  background: rgba(91, 159, 245, 0.12);
}
.voice-bars {
  display: inline-flex;
  gap: 3rpx;
  align-items: flex-end;
  height: 22rpx;
}
.voice-bar {
  width: 5rpx;
  border-radius: 3rpx;
  background: var(--purple);
  animation: voiceBarAnim 0.45s ease-in-out infinite alternate;
}
.voice-bar:nth-child(2) { animation-delay: 0.12s; }
.voice-bar:nth-child(3) { animation-delay: 0.24s; }
@keyframes voiceBarAnim {
  from { height: 6rpx; }
  to { height: 22rpx; }
}
.cmt-voice-dur {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 评论位置 */
.cmt-location {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--teal);
  padding: 4rpx 10rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 8rpx;
}

.cmt-loc-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 评论输入区 */
.cmt-input-area {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.cmt-media-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cmp-item {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cmp-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.cmp-voice-item {
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.cmp-voice-icon {
  font-size: 28rpx;
}

.cmp-voice-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.cmp-voice-dur {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.cmp-loc-item {
  gap: 4rpx;
  padding: 8rpx 14rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--teal);
}

.cmp-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cmp-remove image { width: 20rpx; height: 20rpx; filter: brightness(0) invert(1); }

.cmt-input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cmt-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--bg);
  border-radius: 32rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.cmt-tool-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.cmt-tool-btn.active { background: var(--purple-light); }

.cmt-tool-icon {
  width: 32rpx;
  height: 32rpx;
}

.cmt-tool-btn.recording {
  background: #fef2f2;
}

/* 录音状态条 */
.recording-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  border: 2rpx solid #fecaca;
  margin-bottom: 12rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: recPulse 0.8s infinite;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.rec-text {
  flex: 1;
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 600;
}

.rec-time {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.rec-stop {
  font-size: 24rpx;
  color: #fff;
  background: #ef4444;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.comment-tools-panel {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f8f7fb;
  display: flex;
  gap: 16rpx;
}

.comment-tool-entry {
  width: 116rpx;
  min-height: 92rpx;
  border-radius: 18rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: var(--text-secondary);
  font-size: 21rpx;
  box-shadow: var(--shadow-sm);
}

.comment-tool-entry image {
  width: 38rpx;
  height: 38rpx;
}

.moment-empty-icon { width: 94rpx; height: 94rpx; margin-bottom: 20rpx; opacity: 0.65; }
