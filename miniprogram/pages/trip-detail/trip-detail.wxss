/* 行程详情 · 浅蓝玻璃 */

/* 为底部固定操作栏留空间 */
.page-scroll {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ===== 头部 · 日落渐变 ===== */
.trip-hero {
  background: var(--gradient-trip);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 20rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.trip-hero::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.trip-hero-name {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.trip-hero-more {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.16);
}

.trip-hero-more.active { background: rgba(255,255,255,0.28); }
.trip-hero-more image { width: 40rpx; height: 40rpx; filter: brightness(0) invert(1); }

.trip-manage-menu {
  position: absolute;
  top: 100rpx;
  right: 28rpx;
  z-index: 20;
  width: 300rpx;
  padding: 10rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 18rpx 54rpx rgba(31,25,42,0.22);
}

.trip-manage-item {
  min-height: 84rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: var(--text-primary);
  font-size: 25rpx;
  font-weight: 700;
}

.trip-manage-item:active { background: var(--trip-blue-light); }
.trip-manage-item image { width: 40rpx; height: 40rpx; }
.trip-manage-item.danger { color: var(--red); border-top: 1rpx solid var(--border); }
.trip-manage-item.danger:active { background: #fef2f2; }
.trip-manage-item.danger image {
  filter: brightness(0) saturate(100%) invert(39%) sepia(88%) saturate(1537%) hue-rotate(331deg) brightness(96%) contrast(94%);
}

.trip-hero-city {
  font-size: 28rpx;
  opacity: 0.95;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.trip-hero-dates {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hero-meta-icon {
  width: 26rpx;
  height: 26rpx;
  filter: brightness(0) invert(1);
  flex-shrink: 0;
}

.trip-hero-budget {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 天气横滑条 */
.weather-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
  white-space: nowrap;
  position: relative;
  z-index: 1;
}
.weather-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  width: 92rpx;
  margin-right: 16rpx;
  padding: 10rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.15);
  vertical-align: top;
}
.weather-date { font-size: 19rpx; opacity: 0.75; font-weight: 600; }
.weather-temp { font-size: 20rpx; font-weight: 700; }
.weather-text { font-size: 18rpx; opacity: 0.8; white-space: nowrap; }
.weather-state { position: relative; z-index: 1; margin-top: 16rpx; padding-top: 14rpx; border-top: 1rpx solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.82); font-size: 21rpx; }
.weather-error { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.weather-error > text:first-child { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.weather-retry { flex-shrink: 0; color: #fff; font-weight: 700; }

/* 倒计时 */
.trip-countdown {
  font-size: 21rpx;
  font-weight: 700;
  padding: 2rpx 14rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
  display: inline-block;
  vertical-align: middle;
}
.countdown-upcoming { background: rgba(255,255,255,0.25); color: #fff; }
.countdown-active { background: rgba(255,255,255,0.3); color: #fff; animation: countdownPulse 2s ease-in-out infinite; }
.countdown-done { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.6); }
@keyframes countdownPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 预算进度条 */
.budget-progress-wrap {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: var(--radius);
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}
.budget-progress-bar {
  height: 16rpx;
  border-radius: 8rpx;
  background: var(--trip-blue-soft);
  overflow: hidden;
  margin-bottom: 12rpx;
}
.budget-progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: var(--gradient-trip);
  transition: width 0.4s ease;
}
.budget-progress-fill.over { background: #ef4444; }
.budget-progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  font-weight: 500;
}
.budget-over-text { color: #ef4444; font-weight: 700; }

/* 每日预算卡片 */
.daily-budget-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.dbc-left, .dbc-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.dbc-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--border);
  margin: 0 24rpx;
}

.dbc-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.dbc-budget {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--trip-blue-deep);
}

.dbc-spent {
  font-size: 28rpx;
  font-weight: 800;
}

.dbc-spent.over { color: #ef4444; }

.dbc-remain {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  font-weight: 700;
  color: #10b981;
}

.dbc-remain.over { color: #ef4444; }

/* 迷你饼图卡片 */
.mini-chart-card {
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.mini-chart-canvas {
  display: block;
  margin: 0 auto;
}

/* 票据/语音标签图标 */
.ei-tag-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 6rpx;
  opacity: 0.5;
  vertical-align: middle;
}

/* 计划工具栏 */
.plan-toolbar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.plan-toolbar .day-dropdown { margin-bottom: 0; }

/* AI 搜索栏（卡片和 tab 之间） */
.ai-search-bar {
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.ai-search-input {
  flex: 1;
  font-size: 26rpx;
  height: 48rpx;
  line-height: 48rpx;
  color: var(--text-primary);
}
.ai-search-input::placeholder { color: var(--text-hint); }
.ai-search-submit { height: 46rpx; padding: 0 18rpx; border-radius: 15rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: var(--gradient-trip); color: #fff; font-size: 22rpx; font-weight: 700; box-shadow: 0 5rpx 14rpx rgba(91,159,245,0.22); }

/* 搜索提示文字 */
.ai-search-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
}

/* AI modal */
.ai-modal { max-height: 80vh; display: flex; flex-direction: column; }
.ai-form { margin-bottom: 20rpx; }
.ai-city { font-size: 28rpx; font-weight: 700; color: var(--trip-blue-deep); padding: 12rpx 0; }
.ai-loading { display: flex; flex-direction: column; align-items: center; gap: 18rpx; padding: 48rpx 0; color: var(--text-secondary); font-size: 26rpx; }
.ai-loading-dot {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(91,159,245,0.18);
  border-top-color: var(--trip-blue);
  animation: aiSpin 0.8s linear infinite;
}
@keyframes aiSpin { to { transform: rotate(360deg); } }
.ai-error { padding: 32rpx 20rpx; text-align: center; color: #ef4444; font-size: 26rpx; }
.ai-plan-preview { flex: 1; min-height: 0; }
.ai-plan-scroll { max-height: 56vh; }
.ai-plan-day { margin-bottom: 18rpx; }
.ai-plan-day-label { font-size: 26rpx; font-weight: 800; color: var(--trip-blue-deep); margin-bottom: 8rpx; padding-bottom: 6rpx; border-bottom: 2rpx solid var(--trip-blue-light); }
.ai-plan-item { display: flex; align-items: center; gap: 12rpx; padding: 10rpx 8rpx; border-radius: 10rpx; }
.ai-plan-item:nth-child(odd) { background: var(--trip-blue-soft); }
.ai-plan-time { font-size: 22rpx; color: var(--text-hint); min-width: 72rpx; font-weight: 600; flex-shrink: 0; }
.ai-plan-title { font-size: 26rpx; color: var(--text-primary); font-weight: 600; flex-shrink: 0; }
.ai-plan-loc { font-size: 21rpx; color: var(--text-hint); margin-left: auto; flex-shrink: 0; }
.ai-ledger-answer, .ai-expense-draft { padding: 24rpx; border-radius: 22rpx; background: var(--gradient-trip-soft); border: 1rpx solid rgba(125,185,248,0.22); }
.ai-result-label { color: var(--trip-blue-deep); font-size: 23rpx; font-weight: 750; }
.ai-result-copy { margin-top: 16rpx; color: var(--text-primary); font-size: 28rpx; line-height: 1.65; }
.ai-expense-amount { margin: 18rpx 0 22rpx; color: var(--text-primary); font-size: 52rpx; font-weight: 800; letter-spacing: -1rpx; }
.ai-expense-row { min-height: 54rpx; display: flex; align-items: flex-start; justify-content: space-between; gap: 28rpx; border-top: 1rpx solid rgba(125,185,248,0.14); color: var(--text-primary); font-size: 24rpx; padding-top: 14rpx; box-sizing: border-box; }
.ai-expense-row > text:first-child { color: var(--text-hint); flex-shrink: 0; }
.ai-expense-row > text:last-child { text-align: right; }
.ai-expense-split { max-width: 430rpx; line-height: 1.45; }
.ai-confirm-note { margin-top: 18rpx; color: var(--text-hint); font-size: 20rpx; text-align: center; }
.ai-modal-btns { display: flex; gap: 16rpx; margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx solid var(--border); }
.ai-modal-btns .btn { flex: 1; }

/* 成员行 */
.member-row {
  display: flex;
  margin-top: 24rpx;
  padding-top: 20rpx;
  white-space: nowrap;
  position: relative;
  z-index: 1;
}

.member-avatar {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 76rpx;
  min-height: 102rpx;
  margin-right: 28rpx;
  position: relative;
  vertical-align: top;
}

.member-avatar-img {
  width: 68rpx;
  height: 68rpx;
  box-sizing: border-box;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
}

.member-avatar-placeholder {
  width: 68rpx;
  height: 68rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.member-name {
  font-size: 20rpx;
  line-height: 28rpx;
  margin-top: 6rpx;
  opacity: 0.9;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-badge {
  position: absolute;
  top: -8rpx;
  right: -6rpx;
  font-size: 24rpx;
  color: #dbeafe;
  filter: drop-shadow(0 1rpx 2rpx rgba(0,0,0,0.2));
}

.member-add {
  width: 68rpx;
  height: 68rpx;
  box-sizing: border-box;
  border-radius: 50%;
  border: 2rpx dashed rgba(255,255,255,0.65);
  background: rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
}

.plus-glyph {
  display: block;
  line-height: 1;
  transform: translateY(-4rpx);
}

.invite-row {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 1;
  position: relative;
}

.invite-label {
  font-size: 22rpx;
  opacity: 0.7;
}

.invite-code {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.invite-copy-hint {
  font-size: 20rpx;
  opacity: 0.5;
  margin-left: 4rpx;
}

/* ===== 二级 Tab · 浅蓝胶囊 ===== */
.detail-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: var(--card-bg);
  color: var(--text-secondary);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
}

.tab-emoji { font-size: 28rpx; }

.tab-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.tab-plan.active,
.tab-expense.active,
.tab-moments.active { background: var(--gradient-trip); color: #fff; }

.start-plan-btn {
  margin-top: 20rpx;
  background: var(--gradient-trip) !important;
  color: #fff !important;
  box-shadow: 0 8rpx 22rpx rgba(91, 159, 245, 0.24);
}

.history-readonly-banner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(91,159,245,0.18);
  border-radius: 18rpx;
  background: var(--gradient-trip-soft);
}
.history-readonly-banner > image { width: 34rpx; height: 34rpx; flex-shrink: 0; }
.history-readonly-title { color: #315d8d; font-size: 23rpx; font-weight: 750; }
.history-readonly-copy { margin-top: 3rpx; color: var(--text-hint); font-size: 19rpx; }

.trip-summary-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.16);
  border-radius: 28rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: 0 12rpx 34rpx rgba(39, 96, 170, 0.06);
}

.summary-entry-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 880;
}

.summary-entry-copy {
  margin-top: 6rpx;
  color: #8d98a8;
  font-size: 22rpx;
}

.trip-summary-entry > image {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.48;
  flex-shrink: 0;
}

.trip-vote-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.16);
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(125, 185, 248, 0.18), transparent 36%),
    rgba(255,255,255,0.84);
  box-shadow: 0 12rpx 34rpx rgba(39, 96, 170, 0.06);
}

.vote-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-trip-soft);
  flex-shrink: 0;
}

.vote-entry-icon image {
  width: 36rpx;
  height: 36rpx;
}

.vote-entry-copy {
  flex: 1;
  min-width: 0;
}

.vote-entry-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 880;
}

.vote-entry-text {
  margin-top: 6rpx;
  color: #8d98a8;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vote-entry-arrow {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.48;
  flex-shrink: 0;
}

.trip-reminders {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.trip-reminder {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 26rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: 0 12rpx 34rpx rgba(39, 96, 170, 0.06);
}

.reminder-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--trip-blue);
  box-shadow: 0 0 0 8rpx rgba(91, 159, 245, 0.10);
  flex-shrink: 0;
}

.reminder-budget-danger .reminder-dot {
  background: #ef4444;
  box-shadow: 0 0 0 8rpx rgba(239, 68, 68, 0.10);
}

.reminder-copy {
  flex: 1;
  min-width: 0;
}

.reminder-title {
  color: var(--text-primary);
  font-size: 25rpx;
  font-weight: 850;
}

.reminder-text {
  margin-top: 4rpx;
  color: #7d8796;
  font-size: 21rpx;
  line-height: 1.4;
}

.reminder-action {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  font-size: 21rpx;
  font-weight: 800;
}

/* ===== 日期下拉 ===== */
.day-dropdown {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
  background: var(--trip-blue-light);
  border: 1rpx solid rgba(91, 159, 245, 0.24);
  border-radius: 20rpx;
  position: relative;
  z-index: 11;
}

.day-dropdown-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--trip-blue-deep);
}

.day-dropdown-arrow {
  font-size: 18rpx;
  color: var(--trip-blue-deep);
  transition: transform 0.2s;
}

.day-dropdown-arrow.open {
  transform: rotate(180deg);
}

.day-dropdown-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 12;
}

.day-dropdown-menu {
  position: relative;
  z-index: 13;
  margin-top: -8rpx;
  margin-bottom: 16rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  overflow: hidden;
  max-width: 360rpx;
}

.day-dropdown-item {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  border-top: 1rpx solid var(--border);
}

.day-dropdown-item:first-child {
  border-top: none;
}

.day-dropdown-item.active {
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
}

/* ===== 行程项 ===== */
.plan-day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}

.plan-day-label {
  font-size: 28rpx;
  font-weight: 800;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.plan-day-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.plan-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 8rpx;
  border-radius: var(--radius-sm);
  background: var(--card-bg);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.plan-item-time {
  font-size: 24rpx;
  font-weight: 600;
  min-width: 80rpx;
  padding-top: 2rpx;
}

/* 多彩时间线圆点 */
.plan-item-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.plan-dot-0,
.plan-dot-1,
.plan-dot-2,
.plan-dot-3,
.plan-dot-4 { background: var(--gradient-trip); }

.plan-item-content {
  flex: 1;
}

.plan-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.plan-item-loc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.plan-item-loc image { width: 24rpx; height: 24rpx; }

.plan-item-notes {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.plan-item-del {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--red-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plan-swipe { position: relative; margin-bottom: 14rpx; border-radius: var(--radius); overflow: hidden; }
.plan-swipe.readonly { overflow: visible; }
.plan-swipe .plan-item { margin-bottom: 0; position: relative; z-index: 2; transition: transform 0.22s ease; }
.plan-swipe .plan-item.swiped { transform: translateX(-224rpx); }
.plan-swipe-actions { position: absolute; top: 0; right: 0; bottom: 0; width: 224rpx; display: flex; z-index: 1; }
.plan-swipe-action { width: 112rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 25rpx; font-weight: 700; }
.plan-swipe-action.edit { background: var(--trip-blue); }
.plan-swipe-action.delete { background: #ef4444; }
.mi-action.readonly { opacity: 0.58; }

.plan-add-btn {
  padding: 18rpx;
  font-size: 24rpx;
  color: var(--trip-blue-deep);
  font-weight: 600;
  border: 2rpx dashed rgba(91, 159, 245, 0.42);
  background: rgba(236, 245, 255, 0.48);
  border-radius: var(--radius-sm);
  margin: 8rpx 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.plan-add-btn:active { background: rgba(219, 234, 254, 0.72); }

.plan-add-btn image {
  width: 30rpx;
  height: 30rpx;
  filter: brightness(0) saturate(100%) invert(54%) sepia(73%) saturate(725%) hue-rotate(184deg) brightness(99%) contrast(93%);
}

/* ===== 消费统计 · 三色渐变卡片 ===== */
.expense-stats {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.expense-stat {
  flex: 1;
  border-radius: var(--radius);
  padding: 24rpx;
  text-align: center;
  color: #fff;
}

.es-total,
.es-shared,
.es-private { background: var(--gradient-trip); }

.es-num {
  font-size: 34rpx;
  font-weight: 800;
}

.es-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

/* ===== 消费列表 ===== */
.expense-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.ei-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  overflow: hidden;
}

/* 多彩分类图标 */
.ei-cat {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.ei-cat-icon {
  width: 34rpx;
  height: 34rpx;
}

.ei-cat-transport,
.ei-cat-hotel,
.ei-cat-food,
.ei-cat-tickets,
.ei-cat-shopping,
.ei-cat-other { background: var(--gradient-trip-soft); }

.ei-info {
  flex: 1;
  overflow: hidden;
}

.ei-desc {
  font-size: 26rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ei-paid {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.ei-refund {
  color: #10b981;
  font-weight: 600;
}

.ei-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ===== 动态 ===== */
.moment-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
}

.mi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mi-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mi-avatar, .mi-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.mi-avatar-placeholder {
  background: var(--gradient-trip-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--trip-blue-deep);
  font-weight: 600;
}

.mi-name {
  font-size: 26rpx;
  font-weight: 600;
}

.mi-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mi-verified-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.mi-badge-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.mi-status-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.mi-time {
  font-size: 22rpx;
  color: var(--text-hint);
}


.mi-text {
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.mi-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: var(--bg);
}

.mi-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.mi-video {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mi-video-play {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-video-play image { width: 46rpx; height: 46rpx; filter: brightness(0) invert(1); }

.mi-video-dur {
  position: absolute;
  bottom: 8rpx;
  right: 10rpx;
  font-size: 22rpx;
  color: #a5b4fc;
  background: rgba(0,0,0,0.5);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.mi-location {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.mi-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 互动栏 */
.mi-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  padding-top: 14rpx;
}

.mi-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  min-height: var(--icon-touch);
  padding: 8rpx 12rpx;
  box-sizing: border-box;
}

.mi-action-icon {
  font-size: 34rpx;
}

.mi-action-icon-img {
  width: var(--icon-sm);
  height: var(--icon-sm);
  opacity: var(--icon-muted-opacity);
}

.mi-action.liked .mi-action-icon-img,
.mi-action.favorited .mi-action-icon-img { opacity: var(--icon-active-opacity); }

.mi-action-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e1e2e;
}

.mi-action.liked .mi-action-icon {
  color: var(--trip-blue-deep);
}

.mi-action.favorited .mi-action-icon {
  color: var(--trip-blue-deep);
}

/* 右上角更多按钮 */
.mi-more {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #e5e7eb;
}

.mi-more:active {
  background: #d1d5db;
}

.mi-more-icon {
  font-size: 32rpx;
  color: #374151;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1;
}

/* 管理菜单 */
.mi-menu {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 20;
  overflow: hidden;
  min-width: 220rpx;
}

.mi-menu-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
}

.mi-menu-item:active {
  background: var(--bg);
}

.mi-menu-item.danger {
  color: var(--red);
}

/* 评论区 */
.mi-comments {
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.cmt-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cmt-item {
  display: flex;
  gap: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.cmt-body {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.cmt-author {
  color: var(--trip-blue-deep);
  font-weight: 600;
  flex-shrink: 0;
}

.cmt-text {
  color: var(--text-primary);
}

.cmt-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  display: block;
}

/* 评论语音 */
.cmt-voice {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.cmt-voice-icon {
  font-size: 24rpx;
}

.cmt-voice-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.cmt-voice.voice-playing {
  background: rgba(91, 159, 245, 0.12);
}
.voice-bars {
  display: inline-flex;
  gap: 3rpx;
  align-items: flex-end;
  height: 22rpx;
}
.voice-bar {
  width: 5rpx;
  border-radius: 3rpx;
  background: var(--trip-blue);
  animation: voiceBarAnim 0.45s ease-in-out infinite alternate;
}
.voice-bar:nth-child(2) { animation-delay: 0.12s; }
.voice-bar:nth-child(3) { animation-delay: 0.24s; }
@keyframes voiceBarAnim {
  from { height: 6rpx; }
  to { height: 22rpx; }
}
.cmt-voice-dur {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 评论位置 */
.cmt-location {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--trip-blue-deep);
  padding: 4rpx 10rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 8rpx;
}

.cmt-loc-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 评论输入区 */
.cmt-input-area {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.cmt-media-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cmp-item {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cmp-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.cmp-voice-item {
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.cmp-voice-icon {
  font-size: 28rpx;
}

.cmp-voice-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.cmp-voice-dur {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.cmp-loc-item {
  gap: 4rpx;
  padding: 8rpx 14rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--trip-blue-deep);
}

.cmp-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cmp-remove image { width: 20rpx; height: 20rpx; filter: brightness(0) invert(1); }

.cmt-input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cmt-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: var(--bg);
  border-radius: 32rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.cmt-tool-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.cmt-tool-icon {
  width: 32rpx;
  height: 32rpx;
}

.cmt-tool-btn.recording {
  background: #fef2f2;
}

/* 录音状态条 */
.recording-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  border: 2rpx solid #fecaca;
  margin-bottom: 12rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: recPulse 0.8s infinite;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.rec-text {
  flex: 1;
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 600;
}

.rec-time {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.rec-stop {
  font-size: 24rpx;
  color: #fff;
  background: #ef4444;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.cmt-send {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--trip-blue-deep);
  padding: 0 12rpx;
  flex-shrink: 0;
}

.detail-empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.tab-section-head {
  margin-bottom: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tab-section-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
}

.tab-section-subtitle {
  margin-top: 4rpx;
  color: var(--text-hint);
  font-size: 21rpx;
}

.tab-section-action {
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: var(--gradient-trip);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  font-size: 23rpx;
  font-weight: 800;
  flex-shrink: 0;
  box-sizing: border-box;
}

.tab-section-action image {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* ===== 地点选择器 ===== */
.form-location-picker {
  display: flex;
  align-items: center;
  cursor: pointer;
}

.form-location-text {
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.form-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.form-location-placeholder {
  color: var(--text-hint);
}

.form-time-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.form-time-picker.placeholder { color: var(--text-hint); }

.form-time-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.42;
  flex-shrink: 0;
}

.plan-type-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.plan-type-chip { min-width: 94rpx; height: 56rpx; padding: 0 18rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; background: var(--trip-blue-soft); border: 1rpx solid rgba(125,185,248,0.22); color: var(--text-secondary); font-size: 23rpx; box-sizing: border-box; }
.plan-type-chip.active { color: #fff; background: var(--gradient-trip); border-color: transparent; box-shadow: 0 6rpx 16rpx rgba(91,159,245,0.18); }

/* 添加活动弹窗：覆盖全局旧珊瑚色，统一为行程浅蓝主题 */
.modal-content .form-input {
  border: 2rpx solid rgba(125, 185, 248, 0.24);
  background: var(--trip-blue-soft);
}

.modal-content .form-input:focus {
  border-color: var(--trip-blue);
  background: #fff;
  box-shadow: 0 0 0 5rpx rgba(91, 159, 245, 0.10);
}

.modal-content .btn-primary {
  background: var(--gradient-trip);
  box-shadow: 0 8rpx 22rpx rgba(91, 159, 245, 0.24);
}

.modal-content .btn-outline {
  color: var(--trip-blue-deep);
  border-color: rgba(91, 159, 245, 0.56);
  background: var(--trip-blue-soft);
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-bg);
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
  min-width: 100rpx;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
  flex-shrink: 0;
}

.action-label {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 500;
}
