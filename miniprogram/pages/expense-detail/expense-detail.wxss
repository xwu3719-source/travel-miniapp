/* 账单详情 */

.detail-hero {
  padding: 34rpx 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(125, 185, 248, 0.18);
  text-align: center;
}

.detail-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 18rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-trip-soft);
}

.detail-icon image {
  width: 48rpx;
  height: 48rpx;
}

.detail-desc {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.detail-amount {
  margin-top: 12rpx;
  color: var(--trip-blue-deep);
  font-size: 60rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
}

.detail-refund {
  margin-top: 8rpx;
  color: #10b981;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-tags {
  margin-top: 18rpx;
  display: flex;
  justify-content: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.detail-tags text {
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  font-size: 22rpx;
  font-weight: 700;
}

.section-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(125, 185, 248, 0.14);
}

.section-title {
  margin-bottom: 16rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
}

.info-row {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid rgba(125, 185, 248, 0.10);
  color: var(--text-primary);
  font-size: 25rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row text:first-child {
  color: var(--text-hint);
}

.split-summary {
  margin-bottom: 12rpx;
  color: var(--trip-blue-deep);
  font-size: 23rpx;
  font-weight: 700;
}

.split-member {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-top: 1rpx solid rgba(125, 185, 248, 0.10);
}

.split-avatar {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
}

.split-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-trip-soft);
  color: var(--trip-blue-deep);
  font-size: 20rpx;
  font-weight: 800;
}

.split-name {
  flex: 1;
  color: var(--text-primary);
  font-size: 25rpx;
  font-weight: 700;
}

.split-share {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 750;
}

.attach-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-top: 1rpx solid rgba(125, 185, 248, 0.10);
}

.attach-row:first-of-type {
  border-top: none;
}

.attach-row image {
  width: 36rpx;
  height: 36rpx;
}

.attach-row text:nth-child(2) {
  flex: 1;
  color: var(--text-primary);
  font-size: 25rpx;
  font-weight: 700;
}

.attach-arrow {
  color: var(--text-hint);
  font-size: 34rpx;
}

.refund-item {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid rgba(125, 185, 248, 0.10);
}

.refund-item:first-of-type {
  border-top: none;
}

.refund-desc {
  color: var(--text-primary);
  font-size: 25rpx;
  font-weight: 700;
}

.refund-time {
  margin-top: 4rpx;
  color: var(--text-hint);
  font-size: 21rpx;
}

.refund-amount {
  color: #10b981;
  font-size: 26rpx;
  font-weight: 800;
}

.action-grid {
  margin-top: 24rpx;
  padding-bottom: 44rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: var(--shadow-sm);
}

.action-btn.primary {
  color: #fff;
  background: var(--gradient-trip);
}

.action-btn.danger {
  color: #ef4444;
  background: #fff5f5;
}

.readonly-tip {
  margin: 26rpx 0 44rpx;
  color: var(--text-hint);
  text-align: center;
  font-size: 23rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(15, 23, 42, 0.36);
  box-sizing: border-box;
}

.refund-modal {
  width: 100%;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.modal-title {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 850;
}

.modal-subtitle {
  margin-top: 8rpx;
  color: var(--text-hint);
  font-size: 22rpx;
}

.modal-input {
  margin-top: 18rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #f3f6fb;
  color: var(--text-primary);
  font-size: 25rpx;
  box-sizing: border-box;
}

.modal-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 14rpx;
}

.modal-btn {
  height: 76rpx;
  flex: 1;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.modal-btn.secondary {
  background: #f3f6fb;
  color: var(--text-secondary);
}

.modal-btn.primary {
  color: #fff;
  background: var(--gradient-trip);
}

/* ══════ 账单详情布局 polish ══════ */
.page-scroll {
  background:
    radial-gradient(circle at 20% 0%, rgba(125, 185, 248, 0.18), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 100%);
}

.detail-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 28rpx 32rpx;
  color: #fff;
  border: none;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 82% 8%, rgba(255,255,255,0.36), transparent 27%),
    var(--gradient-trip);
  box-shadow: 0 22rpx 54rpx rgba(91, 159, 245, 0.23);
}

.detail-icon {
  background: rgba(255, 255, 255, 0.22);
}

.detail-icon image {
  filter: brightness(0) invert(1);
}

.detail-desc,
.detail-amount {
  color: #fff;
}

.detail-refund {
  color: rgba(236, 253, 245, 0.95);
}

.detail-tags text {
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.18);
}

.section-card {
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 14rpx 38rpx rgba(39, 96, 170, 0.07);
}

.section-title {
  letter-spacing: 1rpx;
}

.info-row,
.split-member,
.attach-row,
.refund-item {
  border-color: rgba(125, 185, 248, 0.12);
}

.split-summary {
  display: inline-flex;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(236, 245, 255, 0.92);
}

.split-avatar.placeholder {
  background: var(--gradient-trip-soft);
}

.attach-row {
  padding: 4rpx 0;
}

.attach-row image {
  padding: 12rpx;
  border-radius: 20rpx;
  background: var(--gradient-trip-soft);
}

.action-grid {
  gap: 16rpx;
}

.action-btn {
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 12rpx 32rpx rgba(39, 96, 170, 0.06);
}

.action-btn.primary {
  border-color: transparent;
  box-shadow: 0 16rpx 36rpx rgba(91, 159, 245, 0.22);
}

.refund-modal {
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 34rpx;
}

.modal-input {
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 22rpx;
  background: rgba(247, 250, 255, 0.92);
}
