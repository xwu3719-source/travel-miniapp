page { height: 100%; background: #f5f8fd; }
.ai-page { height: 100vh; display: flex; flex-direction: column; color: var(--text-primary); box-sizing: border-box; }
.ai-hero { padding: 28rpx 30rpx 18rpx; display: flex; align-items: center; gap: 18rpx; }
.ai-logo { width: 76rpx; height: 76rpx; border-radius: 24rpx; background: linear-gradient(135deg, rgba(219,234,254,0.96), rgba(255,255,255,0.72)); border: 1rpx solid rgba(125,185,248,0.36); box-shadow: 0 9rpx 24rpx rgba(91,159,245,0.16); }
.ai-hero-copy { min-width: 0; }.ai-title { font-size: 36rpx; font-weight: 800; }.ai-subtitle { margin-top: 5rpx; color: var(--text-hint); font-size: 22rpx; }
.context-scroll { width: 100%; white-space: nowrap; flex-shrink: 0; }.context-row { display: inline-flex; gap: 12rpx; padding: 4rpx 30rpx 18rpx; }
.context-chip { height: 54rpx; padding: 0 20rpx; border-radius: 18rpx; display: flex; align-items: center; background: rgba(255,255,255,0.86); border: 1rpx solid rgba(125,185,248,0.16); color: var(--text-secondary); font-size: 22rpx; box-sizing: border-box; }
.context-chip.active { color: var(--trip-blue-deep); background: var(--gradient-trip-soft); border-color: rgba(91,159,245,0.36); font-weight: 700; }
.chat-scroll { flex: 1; min-height: 0; padding: 0 28rpx; box-sizing: border-box; }.quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; margin: 10rpx 0 24rpx; }
.quick-card { min-height: 92rpx; padding: 18rpx; border-radius: 22rpx; background: rgba(255,255,255,0.88); border: 1rpx solid rgba(125,185,248,0.15); box-shadow: 0 7rpx 20rpx rgba(55,95,145,0.06); display: flex; align-items: center; gap: 14rpx; box-sizing: border-box; }
.quick-card image { width: 34rpx; height: 34rpx; opacity: 0.72; }.quick-card text { font-size: 24rpx; font-weight: 650; }
.message-row { display: flex; margin: 14rpx 0; }.message-row.user { justify-content: flex-end; }
.message-bubble { max-width: 78%; padding: 18rpx 22rpx; border-radius: 22rpx; background: #fff; color: var(--text-primary); font-size: 26rpx; line-height: 1.55; box-shadow: 0 6rpx 18rpx rgba(55,95,145,0.06); box-sizing: border-box; }
.message-row.assistant .message-bubble { border-bottom-left-radius: 8rpx; }.message-row.user .message-bubble { color: #fff; background: var(--gradient-trip); border-bottom-right-radius: 8rpx; box-shadow: 0 8rpx 20rpx rgba(91,159,245,0.18); }
.message-bubble.loading { display: flex; gap: 8rpx; align-items: center; min-width: 92rpx; }.message-bubble.loading view { width: 9rpx; height: 9rpx; border-radius: 50%; background: #7db9f8; animation: aiDot 1s infinite ease-in-out; }.message-bubble.loading view:nth-child(2) { animation-delay: 0.15s; }.message-bubble.loading view:nth-child(3) { animation-delay: 0.3s; }
@keyframes aiDot { 0%, 100% { opacity: 0.3; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-5rpx); } }
.confirm-card { margin: 18rpx 0 8rpx; padding: 26rpx; border-radius: 26rpx; background: rgba(255,255,255,0.94); border: 1rpx solid rgba(125,185,248,0.22); box-shadow: 0 12rpx 30rpx rgba(55,95,145,0.09); }
.confirm-label { color: var(--trip-blue-deep); font-size: 22rpx; font-weight: 750; }.confirm-title { margin: 14rpx 0 18rpx; color: var(--text-primary); font-size: 32rpx; font-weight: 800; }.confirm-amount { margin: 14rpx 0 20rpx; font-size: 52rpx; font-weight: 850; }
.confirm-row { min-height: 58rpx; padding: 13rpx 0; border-top: 1rpx solid rgba(125,185,248,0.13); display: flex; justify-content: space-between; gap: 26rpx; color: var(--text-primary); font-size: 24rpx; box-sizing: border-box; }.confirm-row text:first-child { color: var(--text-hint); flex-shrink: 0; }.confirm-row text:last-child { text-align: right; }
.plan-preview { min-height: 52rpx; border-top: 1rpx solid rgba(125,185,248,0.13); display: flex; align-items: center; justify-content: space-between; color: var(--text-secondary); font-size: 23rpx; }
.packing-preview { max-height: 520rpx; overflow: auto; border-top: 1rpx solid rgba(125,185,248,0.13); }
.packing-suggestion { min-height: 72rpx; padding: 12rpx 0; display: flex; align-items: center; gap: 16rpx; border-bottom: 1rpx solid rgba(125,185,248,0.10); }
.packing-suggestion:last-child { border-bottom: none; }
.packing-check { width: 38rpx; height: 38rpx; border-radius: 50%; border: 2rpx solid rgba(125,185,248,0.5); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 22rpx; font-weight: 800; box-sizing: border-box; flex-shrink: 0; }
.packing-suggestion.selected .packing-check { border-color: transparent; background: var(--gradient-trip); box-shadow: 0 6rpx 14rpx rgba(91,159,245,0.18); }
.packing-info { min-width: 0; flex: 1; }
.packing-name { color: var(--text-primary); font-size: 25rpx; font-weight: 750; line-height: 1.35; }
.packing-reason { margin-top: 4rpx; color: var(--text-hint); font-size: 21rpx; line-height: 1.35; }
.confirm-note { margin-top: 14rpx; color: var(--text-hint); font-size: 20rpx; text-align: center; }.confirm-actions { margin-top: 20rpx; display: flex; gap: 14rpx; }.confirm-btn { height: 72rpx; flex: 1; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 25rpx; font-weight: 700; }.confirm-btn.secondary { color: var(--text-secondary); background: #f2f5f9; }.confirm-btn.primary { color: #fff; background: var(--gradient-trip); box-shadow: 0 7rpx 20rpx rgba(91,159,245,0.2); }.confirm-btn.disabled { opacity: 0.55; }
.chat-bottom-space { height: 150px; }.composer { position: fixed; left: 0; right: 0; bottom: 0; z-index: 20; min-height: 112rpx; padding: 16rpx 24rpx calc(22rpx + env(safe-area-inset-bottom)); display: flex; align-items: flex-start; gap: 12rpx; background: rgba(255,255,255,0.88); border-top: 1rpx solid rgba(125,185,248,0.12); -webkit-backdrop-filter: blur(18rpx); backdrop-filter: blur(18rpx); box-sizing: border-box; transition: bottom 0.18s ease; }
.composer-input { height: 72rpx; flex: 1; padding: 0 22rpx; border-radius: 22rpx; background: #f3f6fb; color: var(--text-primary); font-size: 24rpx; box-sizing: border-box; }.composer-send { height: 72rpx; padding: 0 22rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; color: #a7b0bc; background: #edf1f6; font-size: 24rpx; font-weight: 700; box-sizing: border-box; }.composer-send.active { color: #fff; background: var(--gradient-trip); box-shadow: 0 7rpx 20rpx rgba(91,159,245,0.2); }
