/* 首页 - 行程列表 · 彩趣版 */

.index-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.index-title {
  font-size: 44rpx;
  font-weight: 800;
  background: var(--gradient-sunset);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.index-actions {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

/* ===== 行程卡片 ===== */
.trip-card-row {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: var(--radius);
}

.trip-swipe-del {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100rpx;
  background: #ef4444;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 0 var(--radius) var(--radius) 0;
  z-index: 1;
}

.trip-card {
  position: relative;
  z-index: 2;
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.25s ease;
}

.trip-card.swiped {
  transform: translateX(-100rpx);
}

/* 左侧渐变彩条 · 五行配色自动轮换 */
.trip-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 3rpx 0 0 3rpx;
}

.trip-card-row:nth-child(5n+1)::before { background: var(--gradient-coral); }
.trip-card-row:nth-child(5n+2)::before { background: var(--gradient-ocean); }
.trip-card-row:nth-child(5n+3)::before { background: var(--gradient-purple); }
.trip-card-row:nth-child(5n+4)::before { background: var(--gradient-amber); }
.trip-card-row:nth-child(5n+5)::before { background: var(--gradient-teal); }

.trip-card:active {
  background: #f3f4f6;
}

.trip-card.archived::before {
  background: #d1d5db !important;
  opacity: 0.5;
}

.trip-card.archived {
  opacity: 0.65;
}

.trip-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.trip-info {
  flex: 1;
}

.trip-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.trip-city {
  font-size: 26rpx;
  color: var(--teal);
  font-weight: 500;
}

.trip-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 200;
  margin-top: -4rpx;
}

.trip-dates {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.trip-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.trip-budget {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg);
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

/* ===== 区块标题 ===== */
.section-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* ===== 历史切换 ===== */
.history-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 4rpx;
  margin-bottom: 8rpx;
}

.history-toggle-text {
  font-size: 26rpx;
  color: var(--text-hint);
  font-weight: 600;
}

.history-toggle-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  transition: transform 0.2s;
}

.history-toggle-arrow.open {
  transform: rotate(90deg);
}

/* ===== 批量选择 ===== */
.trip-card.batch-mode {
  padding-left: 80rpx;
}

.trip-select-circle {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  background: #fff;
  transition: all 0.15s;
}

.trip-select-circle.checked {
  border-color: var(--coral);
  background: var(--coral);
}

.trip-select-circle text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

/* 批量操作底部栏 */
.batch-bar {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 1000;
}

.batch-bar-cancel {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
}

.batch-bar-info {
  font-size: 26rpx;
  color: var(--text-hint);
}

.batch-bar-btn {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
  padding: 8rpx 16rpx;
}

.batch-bar-btn.disabled {
  color: #d1d5db;
  pointer-events: none;
}
