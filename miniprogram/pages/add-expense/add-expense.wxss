/* 添加消费 · 浅蓝玻璃 */

.form-title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 36rpx;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ══════ 预算状态条 ══════ */
.budget-bar-mini {
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.bbm-text {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.bbm-amounts {
  color: var(--trip-blue-deep);
}

.bbm-track {
  height: 12rpx;
  background: var(--bg);
  border-radius: 6rpx;
  overflow: hidden;
}

.bbm-fill {
  height: 100%;
  background: var(--gradient-trip);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.bbm-fill.warn {
  background: linear-gradient(135deg, #7db9f8, #5b9ff5);
}

.bbm-fill.over {
  background: linear-gradient(135deg, #ef4444, #f43f5e);
}

/* ══════ 模板区 ══════ */
.templates-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 6rpx;
}

.template-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 23rpx;
  font-weight: 500;
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.template-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.template-chip:active {
  border-color: var(--trip-blue);
  background: var(--trip-blue-light);
  color: var(--trip-blue-deep);
}

.toggle-arrow {
  display: inline-block;
  transition: transform 0.25s;
  margin-left: 8rpx;
  color: var(--text-hint);
}

.toggle-arrow.open {
  transform: rotate(90deg);
}

/* ══════ 类型选择 ══════ */
.type-row {
  display: flex;
  gap: 14rpx;
}

.type-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 600;
  background: var(--bg);
  color: var(--text-secondary);
  border: 3rpx solid transparent;
}

.type-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.type-btn.active {
  background: var(--trip-blue-light);
  color: var(--trip-blue-deep);
  border-color: var(--trip-blue);
}

.cat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cat-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.cat-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.cat-btn.active {
  border-color: var(--trip-blue);
  background: var(--trip-blue-light);
  color: var(--trip-blue-deep);
}

/* ══════ 金额 + 快捷按钮 ══════ */
.amount-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.amount-prefix {
  font-size: 36rpx;
  font-weight: 700;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  flex-shrink: 0;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  padding: 24rpx;
  line-height: 48rpx;
  min-width: 0;
}

.quick-amounts {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.qa-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: var(--bg);
  color: var(--trip-blue-deep);
  border: 2rpx solid transparent;
}

.qa-btn:active {
  border-color: var(--trip-blue);
  background: var(--trip-blue-light);
}

.qa-clear {
  background: rgba(239, 68, 68, 0.08);
  color: #ef4444;
  flex: 0.7;
}

/* ══════ 描述 + 语音 ══════ */
.desc-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.desc-input {
  flex: 1;
  min-width: 0;
}

.voice-btn {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
}

.voice-btn:active {
  background: var(--trip-blue-light);
  border-color: var(--trip-blue);
}

.voice-btn.recording {
  background: #fee2e2;
  border-color: #ef4444;
  animation: pulse-rec 1.2s infinite;
}

.voice-btn.has-voice {
  background: #d1fae5;
  border-color: #10b981;
}

@keyframes pulse-rec {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.12); }
}

.voice-icon {
  width: 36rpx;
  height: 36rpx;
}

.voice-dot {
  color: #ef4444;
  font-size: 28rpx;
}

.voice-dur {
  font-size: 22rpx;
  font-weight: 700;
  color: #10b981;
}

.voice-added {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 20rpx;
  background: #d1fae5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #065f46;
}

.voice-remove {
  color: #ef4444;
  font-weight: 600;
}

/* ══════ 票据拍照 ══════ */
.receipt-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.receipt-scan {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
  font-size: 22rpx;
  font-weight: 800;
}

.receipt-scan image {
  width: 26rpx;
  height: 26rpx;
}

.receipt-area {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  border: 3rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.receipt-add-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: var(--text-hint);
  font-size: 22rpx;
}

.receipt-camera-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.5;
}

.receipt-preview {
  width: 100%;
  height: 100%;
}

.receipt-remove {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #ef4444;
}

/* ══════ 通用 ══════ */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-text {
  flex: 1;
}

.picker-arrow {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.split-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.split-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.split-summary {
  color: var(--text-hint);
  font-size: 22rpx;
  font-weight: 500;
}

.split-actions {
  display: flex;
  gap: 12rpx;
  margin: 6rpx 0 16rpx;
}

.split-action {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  font-size: 22rpx;
  font-weight: 700;
}

.split-action.muted {
  color: var(--text-hint);
  background: var(--bg);
}

.split-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  background: var(--bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.split-item.selected {
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
  border-color: rgba(91, 159, 245, 0.30);
}

.split-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.split-check.checked {
  background: var(--gradient-trip);
  border-color: transparent;
  box-shadow: 0 6rpx 14rpx rgba(91, 159, 245, 0.18);
}

/* 按钮 - 浅蓝渐变 */
.btn-primary {
  background: var(--gradient-trip) !important;
  box-shadow: 0 6rpx 20rpx rgba(91, 159, 245, 0.24) !important;
}

/* 覆盖全局 form-input focus 为账本蓝 */
.page-scroll .form-input:focus {
  border-color: var(--trip-blue);
}

/* ══════ 记一笔布局重构 · 金额优先 ══════ */
.page-scroll {
  background:
    radial-gradient(circle at 18% 0%, rgba(125, 185, 248, 0.20), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 100%);
}

.form-title {
  margin: 8rpx 0 22rpx;
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
  font-size: 42rpx;
  letter-spacing: 1rpx;
}

.budget-bar-mini,
.form-group {
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 14rpx 38rpx rgba(39, 96, 170, 0.07);
}

.form-group {
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.expense-compose-card {
  overflow: hidden;
  padding: 30rpx 26rpx 24rpx;
  background:
    radial-gradient(circle at 88% 4%, rgba(255,255,255,0.62), transparent 28%),
    linear-gradient(135deg, rgba(236, 245, 255, 0.94), rgba(255, 255, 255, 0.88));
}

.compose-label {
  color: #7b8798;
  font-size: 24rpx;
  font-weight: 800;
}

.amount-row {
  margin-top: 8rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(125, 185, 248, 0.14);
}

.amount-prefix {
  font-size: 46rpx;
  color: var(--trip-blue-deep);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.amount-input {
  height: 86rpx;
  padding: 0;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-size: 54rpx;
  line-height: 86rpx;
}

.quick-amounts {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.qa-btn {
  flex: 1;
  min-width: 0;
  padding: 12rpx 0;
  border: 1rpx solid rgba(125, 185, 248, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
}

.qa-clear {
  flex: 1;
  color: #ef4444;
  background: rgba(239, 68, 68, 0.07);
}

.compose-type-row {
  margin-top: 20rpx;
}

.type-btn {
  height: 76rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.type-btn.active {
  border-color: rgba(91, 159, 245, 0.34);
  background: var(--gradient-trip);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(91, 159, 245, 0.18);
}

.type-btn.active .type-icon {
  filter: brightness(0) invert(1);
}

.form-label {
  margin-bottom: 16rpx;
  color: var(--text-primary);
  font-size: 27rpx;
  font-weight: 850;
}

.cat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cat-btn {
  flex: 0 0 calc((100% - 24rpx) / 3);
  justify-content: center;
  min-height: 78rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 24rpx;
  background: rgba(247, 250, 255, 0.86);
  box-sizing: border-box;
}

.cat-btn.active {
  border-color: rgba(91, 159, 245, 0.32);
  background: rgba(236, 245, 255, 0.96);
  box-shadow: inset 0 0 0 1rpx rgba(91, 159, 245, 0.08);
}

.desc-row {
  gap: 12rpx;
}

.form-input,
.picker-box {
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 24rpx;
  background: rgba(247, 250, 255, 0.92);
}

.voice-btn {
  border-radius: 26rpx;
  border-color: rgba(125, 185, 248, 0.14);
  background: rgba(247, 250, 255, 0.92);
}

.receipt-area {
  width: 100%;
  height: 156rpx;
  border: 2rpx dashed rgba(91, 159, 245, 0.28);
  border-radius: 28rpx;
  background: rgba(247, 250, 255, 0.72);
  box-sizing: border-box;
}

.receipt-add-btn {
  flex-direction: row;
  color: var(--trip-blue-deep);
  font-weight: 750;
}

.split-actions {
  margin-top: -2rpx;
}

.split-list {
  gap: 12rpx;
}

.split-item {
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 999rpx;
  background: rgba(247, 250, 255, 0.92);
}

.split-check {
  width: 32rpx;
  height: 32rpx;
  border-width: 2rpx;
}

.template-group {
  background: rgba(255, 255, 255, 0.58);
}

.btn-primary {
  margin-top: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(91, 159, 245, 0.24) !important;
}
