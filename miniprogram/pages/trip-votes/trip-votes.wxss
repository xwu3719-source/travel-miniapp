.votes-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(125, 185, 248, 0.22), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #f5f7fb 100%);
}

.votes-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  color: #fff;
  background:
    radial-gradient(circle at 86% 8%, rgba(255,255,255,0.34), transparent 28%),
    var(--gradient-trip);
  box-shadow: 0 22rpx 54rpx rgba(91, 159, 245, 0.23);
}

.votes-kicker {
  color: rgba(255,255,255,0.75);
  font-size: 22rpx;
  font-weight: 800;
}

.votes-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 920;
  line-height: 1.24;
}

.votes-subtitle {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.82);
  font-size: 23rpx;
  line-height: 1.4;
}

.create-vote-btn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: rgba(255,255,255,0.86);
  font-size: 24rpx;
  font-weight: 900;
}

.empty-panel {
  margin-top: 22rpx;
  padding: 56rpx 36rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 34rpx;
  background: rgba(255,255,255,0.88);
  box-shadow: 0 14rpx 38rpx rgba(39, 96, 170, 0.07);
  text-align: center;
}

.empty-panel image {
  width: 78rpx;
  height: 78rpx;
  opacity: 0.78;
}

.empty-title {
  margin-top: 20rpx;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 10rpx;
  color: #8d98a8;
  font-size: 24rpx;
  line-height: 1.45;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  padding: 16rpx 30rpx;
  border-radius: 999rpx;
  color: #fff;
  background: var(--gradient-trip);
  font-size: 25rpx;
  font-weight: 900;
}

.vote-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: 36rpx;
}

.vote-card {
  padding: 26rpx;
  border: 1rpx solid rgba(125,185,248,0.14);
  border-radius: 32rpx;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 14rpx 38rpx rgba(39, 96, 170, 0.07);
}

.vote-card.closed {
  opacity: 0.78;
}

.vote-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.vote-main {
  flex: 1;
  min-width: 0;
}

.vote-type {
  display: inline-flex;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
  font-size: 20rpx;
  font-weight: 850;
}

.vote-title {
  margin-top: 12rpx;
  color: var(--text-primary);
  font-size: 31rpx;
  font-weight: 920;
  line-height: 1.35;
}

.vote-meta {
  margin-top: 8rpx;
  color: #9aa4b2;
  font-size: 22rpx;
}

.vote-status {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #fff;
  background: var(--gradient-trip);
  font-size: 20rpx;
  font-weight: 850;
}

.vote-status.closed {
  color: #8d98a8;
  background: #eef2f7;
}

.option-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-row {
  display: flex;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(247, 250, 255, 0.9);
}

.option-row.selected {
  background: rgba(226, 241, 255, 0.92);
}

.option-check {
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border: 3rpx solid rgba(91,159,245,0.34);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(255,255,255,0.92);
}

.option-check-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--trip-blue);
}

.option-content {
  flex: 1;
  min-width: 0;
}

.option-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.option-text {
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.option-count {
  color: #7f8a9b;
  font-size: 21rpx;
  font-weight: 750;
  flex-shrink: 0;
}

.option-bar {
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(205, 222, 244, 0.45);
}

.option-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--gradient-trip);
}

.vote-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  color: #9aa4b2;
  font-size: 22rpx;
}

.vote-foot-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.adopt-vote {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
  font-weight: 850;
}

.close-vote {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #ef6a6a;
  background: rgba(239,106,106,0.08);
  font-weight: 850;
}

.create-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.18);
  z-index: 20;
}

.create-sheet {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 21;
  padding: 16rpx 26rpx 28rpx;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 -18rpx 64rpx rgba(15, 23, 42, 0.16);
  box-sizing: border-box;
  transition: bottom 0.18s ease;
}

.sheet-scroll {
  max-height: 568px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: #dbe4ee;
}

.sheet-title {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 920;
}

.sheet-label {
  margin-top: 22rpx;
  color: #6f7c91;
  font-size: 23rpx;
  font-weight: 850;
}

.sheet-input,
.sheet-textarea {
  width: 100%;
  margin-top: 12rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  background: #f6f9fd;
  font-size: 26rpx;
}

.sheet-input {
  height: 86rpx;
  min-height: 86rpx;
  padding: 0 22rpx;
  line-height: 86rpx;
}

.sheet-textarea {
  height: 168rpx;
  min-height: 168rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.type-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #7f8a9b;
  background: #f1f5fa;
  font-size: 23rpx;
  font-weight: 820;
}

.type-chip.active {
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
}

.sheet-tip {
  margin-top: 10rpx;
  color: #9aa4b2;
  font-size: 21rpx;
}

.sheet-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.sheet-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.sheet-btn.primary {
  color: #fff;
  background: var(--gradient-trip);
  box-shadow: 0 16rpx 36rpx rgba(91, 159, 245, 0.24);
}

.sheet-btn.secondary {
  color: #6f7c91;
  background: #f1f5fa;
}

.sheet-btn.disabled {
  opacity: 0.62;
}
