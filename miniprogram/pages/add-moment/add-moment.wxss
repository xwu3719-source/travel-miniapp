/* 发布动态 · 紫韵版 */

.form-title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 36rpx;
  background: var(--gradient-purple);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 统一媒体网格 */
.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.media-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.media-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.media-video-preview {
  width: 100%;
  height: 100%;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.media-video-play {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-video-dur {
  font-size: 22rpx;
  color: #a5b4fc;
}

.media-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: var(--bg);
  border: 3rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-add-icon {
  font-size: 56rpx;
  color: var(--purple);
  line-height: 1;
}

.uploading-hint {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

/* 按钮 - 紫色渐变 */
.btn-primary {
  background: var(--gradient-purple) !important;
  box-shadow: 0 6rpx 20rpx rgba(168, 85, 247, 0.35) !important;
}

.day-row {
  display: flex;
  gap: 12rpx;
  white-space: nowrap;
}

.day-chip {
  display: inline-flex;
  padding: 12rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.day-chip.active {
  background: var(--purple-light);
  color: var(--purple);
  border-color: var(--purple);
}

.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 4rpx 0;
}

/* 位置横条 */
.loc-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 24rpx;
  background: var(--bg);
  border-radius: 12rpx;
}

.loc-bar-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.loc-bar-text {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
}

.loc-bar-placeholder {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.loc-bar-remove {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 4rpx;
}
