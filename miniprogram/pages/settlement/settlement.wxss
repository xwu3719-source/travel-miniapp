/* 结算 · 浅蓝玻璃 */

.settle-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.settle-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--trip-blue);
}

.sc-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid var(--border);
}

.sc-avatar, .sc-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.sc-avatar-placeholder {
  background: linear-gradient(135deg, #e0f2fe, #bae6fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--sky);
  font-weight: 600;
}

.sc-name {
  font-size: 30rpx;
  font-weight: 700;
  flex: 1;
}

.sc-badge {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 14rpx;
  font-weight: 600;
}

.sc-badge.earn {
  background: var(--amber-light);
  color: var(--trip-blue-deep);
}

.sc-badge.owe {
  background: var(--coral-light);
  color: var(--coral);
}

.sc-row {
  display: flex;
  gap: 8rpx;
}

.sc-item {
  flex: 1;
  text-align: center;
}

.sc-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 6rpx;
}

.sc-val {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.sc-val.shared { color: var(--trip-blue-deep); }
.sc-val.total { color: var(--trip-blue-deep); font-size: 30rpx; }

/* 转账卡片 */
.transfer-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx 20rpx;
  margin-bottom: 14rpx;
  box-shadow: var(--shadow-sm);
  gap: 12rpx;
  border-left: 6rpx solid var(--amber);
}

.tc-from, .tc-to {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 100rpx;
}

.tc-arrow {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tc-avatar, .tc-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.tc-avatar-placeholder {
  background: linear-gradient(135deg, #e0f2fe, #bae6fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--sky);
  font-weight: 600;
}

.tc-name {
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.tc-amount {
  font-size: 34rpx;
  font-weight: 800;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.tc-arrow-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.46;
}

/* 消费明细 */
.expense-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx 20rpx 20rpx 14rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
  border-left: 6rpx solid #d1d5db;
}

.expense-item:nth-child(5n+1) { border-left-color: #0ea5e9; }
.expense-item:nth-child(5n+2) { border-left-color: #5b9ff5; }
.expense-item:nth-child(5n+3) { border-left-color: #8ec5ff; }
.expense-item:nth-child(5n+4) { border-left-color: #9cc7ff; }
.expense-item:nth-child(5n+5) { border-left-color: #b9c7d8; }

.ei-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  overflow: hidden;
}

.ei-cat {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.ei-cat-icon {
  width: 34rpx;
  height: 34rpx;
}

.ei-cat-transport { background: linear-gradient(135deg, #e0f2fe, #bae6fd); }
.ei-cat-hotel { background: linear-gradient(135deg, #ecf5ff, #c7d9f7); }
.ei-cat-food { background: linear-gradient(135deg, #fff7ed, #fed7aa); }
.ei-cat-tickets { background: linear-gradient(135deg, #fff1f2, #fecdd3); }
.ei-cat-shopping { background: linear-gradient(135deg, #fffbf0, #fde68a); }
.ei-cat-other { background: linear-gradient(135deg, #f3f4f6, #d1d5db); }

.ei-info {
  flex: 1;
  overflow: hidden;
}

.ei-desc {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ei-paid {
  font-size: 22rpx;
  color: var(--text-hint);
}

.ei-paid.refund {
  margin-top: 4rpx;
  color: #10b981;
  font-weight: 600;
}

.ei-amount {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
  flex-shrink: 0;
}

/* ══════ 结算复选框 ══════ */
.settle-expense {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.settle-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  font-weight: 700;
}

.settle-check.checked {
  background: var(--trip-blue);
  border-color: var(--trip-blue);
}

.settlement-toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: -6rpx 0 16rpx;
}

.settlement-summary {
  flex: 1;
  color: var(--trip-blue-deep);
  font-size: 23rpx;
  font-weight: 750;
}

.settlement-tool {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  font-size: 22rpx;
  font-weight: 700;
}

.settlement-tool.muted {
  color: var(--text-hint);
  background: var(--bg);
}

.settled-check-done {
  background: #d1d5db;
  border-color: #d1d5db;
  color: #fff;
}

/* 已结算项 */
.settled-item {
  opacity: 0.55;
  border-left-color: #d1d5db !important;
}

.settled-amount {
  color: var(--text-hint);
}

/* 子标题 */
.settle-subtitle {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-hint);
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

/* 票据标签图标 */
.ei-tag-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 6rpx;
  opacity: 0.5;
  vertical-align: middle;
}

/* ══════ 结算历史 ══════ */
.toggle-arrow {
  display: inline-block;
  transition: transform 0.25s;
  margin-left: 8rpx;
  font-size: 28rpx;
  color: var(--text-hint);
}

.toggle-arrow.open {
  transform: rotate(90deg);
}

.history-item {
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.hi-time {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 6rpx;
}

.hi-summary {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.hi-transfers {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hi-transfer {
  font-size: 22rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 记录结算按钮 */
.btn-primary {
  background: var(--gradient-trip) !important;
  box-shadow: 0 6rpx 20rpx rgba(91, 159, 245, 0.24) !important;
}

/* ══════ 结算布局重构 · 清爽蓝色账务流 ══════ */
.page-scroll {
  background:
    radial-gradient(circle at 24% 0%, rgba(125, 185, 248, 0.18), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 100%);
}

.settlement-hero {
  margin-bottom: 28rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  color: #fff;
  background:
    radial-gradient(circle at 86% 10%, rgba(255,255,255,0.34), transparent 28%),
    var(--gradient-trip);
  box-shadow: 0 22rpx 54rpx rgba(91, 159, 245, 0.23);
}

.settlement-hero-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  font-weight: 750;
}

.settlement-hero-title {
  margin-top: 8rpx;
  font-size: 35rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.settlement-hero-metrics {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.settlement-hero-metric {
  flex: 1;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
}

.settlement-hero-metric text {
  display: block;
}

.settlement-hero-metric text:first-child {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.settlement-hero-metric text:last-child {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 21rpx;
  font-weight: 700;
}

.settle-title {
  margin: 30rpx 2rpx 18rpx !important;
  color: var(--text-primary);
  font-size: 31rpx;
  letter-spacing: 1rpx;
}

.settle-card,
.transfer-card,
.history-item {
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-left: none;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 14rpx 38rpx rgba(39, 96, 170, 0.07);
}

.settle-card {
  padding: 24rpx;
}

.sc-header {
  border-bottom-color: rgba(125, 185, 248, 0.12);
}

.sc-avatar,
.sc-avatar-placeholder,
.tc-avatar,
.tc-avatar-placeholder {
  box-shadow: 0 8rpx 22rpx rgba(39, 96, 170, 0.10);
}

.sc-avatar-placeholder,
.tc-avatar-placeholder {
  color: var(--trip-blue-deep);
  background: var(--gradient-trip-soft);
}

.sc-badge.earn {
  color: #059669;
  background: rgba(16, 185, 129, 0.10);
}

.sc-badge.owe {
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
}

.sc-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sc-item {
  flex: 0 0 calc((100% - 12rpx) / 2);
  padding: 16rpx 10rpx;
  border-radius: 22rpx;
  background: rgba(247, 250, 255, 0.78);
  box-sizing: border-box;
}

.sc-val.shared,
.sc-val.total {
  color: var(--trip-blue-deep);
}

.transfer-card {
  padding: 24rpx;
}

.tc-arrow {
  min-width: 180rpx;
}

.tc-amount {
  color: var(--trip-blue-deep);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.tc-arrow-icon {
  transform: rotate(0deg);
  filter: brightness(0) saturate(100%) invert(59%) sepia(34%) saturate(1111%) hue-rotate(178deg) brightness(101%) contrast(93%);
}

.settlement-toolbar {
  padding: 12rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.12);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.74);
}

.settlement-summary {
  padding-left: 8rpx;
}

.expense-item {
  border: 1rpx solid rgba(125, 185, 248, 0.12) !important;
  border-left: none !important;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 34rpx rgba(39, 96, 170, 0.06);
}

.ei-cat-transport,
.ei-cat-hotel,
.ei-cat-food,
.ei-cat-tickets,
.ei-cat-shopping,
.ei-cat-other {
  border-radius: 22rpx;
  background: var(--gradient-trip-soft);
}

.ei-amount {
  color: var(--trip-blue-deep);
}

.settle-check {
  border-color: rgba(91, 159, 245, 0.30);
  background: #fff;
}

.settle-check.checked {
  background: var(--gradient-trip);
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(91, 159, 245, 0.18);
}

.settle-subtitle {
  margin: 20rpx 2rpx 14rpx;
  color: #8c98a8;
  font-size: 23rpx;
  letter-spacing: 1rpx;
}

.hi-transfer {
  border-radius: 999rpx;
  background: rgba(236, 245, 255, 0.92);
}

.voucher-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 16rpx 0 18rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(125, 185, 248, 0.14);
  border-radius: 28rpx;
  background: rgba(255,255,255,0.84);
  box-shadow: 0 12rpx 34rpx rgba(39, 96, 170, 0.06);
}

.voucher-card.success {
  background: linear-gradient(135deg, rgba(236,245,255,.94), rgba(255,255,255,.86));
}

.voucher-title {
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 880;
}

.voucher-subtitle {
  margin-top: 6rpx;
  color: #8d98a8;
  font-size: 21rpx;
  line-height: 1.4;
}

.voucher-btn,
.hi-copy {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: var(--trip-blue-deep);
  background: var(--trip-blue-light);
  font-size: 22rpx;
  font-weight: 800;
}

.hi-copy {
  display: inline-flex;
  margin-top: 10rpx;
}

.btn-primary {
  box-shadow: 0 16rpx 36rpx rgba(91, 159, 245, 0.24) !important;
}
