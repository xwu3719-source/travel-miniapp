<page-meta page-style="{{themeStyle}}"/>
<message-popup />
<view class="page {{themeClass}}">
  <view class="bg-blob bg-blob-1"></view>
  <view class="bg-blob bg-blob-2"></view>

  <view class="body">
    <!-- 品牌 -->
    <view class="brand-section">
      <view class="logo-circle">
        <image src="/images/icons/reset-password.png" mode="aspectFit" class="logo-icon"/>
      </view>
      <text class="brand-title">重置密码</text>
    </view>

    <!-- Step 1: 验证身份 -->
    <view wx:if="{{step === 1}}" class="card">
      <view class="step-indicator">STEP 1</view>
      <text class="card-title">验证账号身份</text>
      <text class="card-desc">请输入你的 6 位 ID 和用户名来验证身份</text>

      <view class="input-row">
        <input
          class="form-input"
          type="number"
          placeholder="输入你的ID"
          value="{{publicId}}"
          bindinput="onPublicIdInput"
          maxlength="6"
        />
      </view>
      <view class="input-row">
        <input
          class="form-input"
          placeholder="输入你的用户名"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>

      <button
        class="primary-btn"
        bindtap="onVerify"
        loading="{{loading}}"
        disabled="{{loading || !publicId || !username}}"
      >验证身份</button>
    </view>

    <!-- Step 2: 设置新密码 -->
    <view wx:if="{{step === 2}}" class="card">
      <view class="step-indicator">STEP 2</view>
      <text class="card-title">设置新密码</text>
      <text class="card-desc">为账号 {{publicId}} 设置新密码</text>

      <view class="input-row">
        <input
          class="form-input"
          type="password"
          placeholder="新密码（6-30位）"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
          maxlength="30"
        />
      </view>
      <view class="input-row">
        <input
          class="form-input"
          type="password"
          placeholder="确认新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="30"
        />
      </view>

      <button
        class="primary-btn"
        bindtap="onReset"
        loading="{{loading}}"
        disabled="{{loading || !newPassword || !confirmPassword}}"
      >重置密码</button>
    </view>

    <!-- Step 3: 完成 -->
    <view wx:if="{{step === 3}}" class="card success-card">
    <image class="success-icon ui-theme-icon" src="/images/icons/reset-password.png" mode="aspectFit"/>
      <text class="card-title">密码重置成功</text>
      <text class="card-desc">请使用新密码登录</text>
      <button class="primary-btn" bindtap="onGoLogin">去登录</button>
    </view>
  </view>
</view>
