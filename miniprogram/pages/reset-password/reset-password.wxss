/* ═══════════════════════════════════════
   重置密码页 · 浅蓝渐变
   ═══════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f0f7ff 0%, #e0f0ff 35%, #f5faff 70%, #ecf5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 48rpx env(safe-area-inset-bottom);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.bg-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.bg-blob-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(147,197,253,0.12) 0%, transparent 70%);
  top: -60rpx;
  right: -80rpx;
}

.bg-blob-2 {
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(186,219,254,0.10) 0%, transparent 70%);
  bottom: 180rpx;
  left: -80rpx;
}

.body {
  width: 100%;
  max-width: 520rpx;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 品牌 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.logo-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7db9f8, #5b9ff5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(91,159,245,0.25);
}

.logo-icon {
  width: 44rpx;
  height: 44rpx;
  filter: brightness(0) invert(1);
}

.brand-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

/* 卡片 */
.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(91,159,245,0.08);
  padding: 36rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-indicator {
  font-size: 20rpx;
  color: #5b9ff5;
  background: rgba(91,159,245,0.1);
  padding: 4rpx 24rpx;
  border-radius: 16rpx;
  letter-spacing: 4rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.input-row {
  width: 100%;
  margin-bottom: 18rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #ecf5ff;
  border-radius: 14rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #cfe0f8;
  font-size: 26rpx;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #7db9f8, #5b9ff5);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91,159,245,0.3);
  padding: 0;
  border: none;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

.primary-btn::after {
  border: none;
}

.primary-btn[disabled] {
  opacity: 0.5;
}

/* 成功 */
.success-card {
  padding: 48rpx 36rpx;
}

.success-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 16rpx;
}
