<message-popup />
<!-- 加入行程 -->
<view class="container join-page">
  <view class="join-header">
  <image class="join-icon ui-theme-icon" src="/images/icons/trip-members.png" mode="aspectFit"/>
    <view class="join-title">加入行程</view>
    <view class="join-desc">输入朋友分享的邀请码，加入 TA 的旅行</view>
  </view>

  <view class="code-box">
    <input
      class="code-input"
      type="text"
      placeholder="输入邀请码"
      maxlength="6"
      value="{{code}}"
      bindinput="onCodeInput"
      focus="{{true}}"
    />
  </view>

  <view class="btn btn-primary btn-block" bindtap="onJoin">
      <image wx:if="{{!joining}}" class="ui-inline-icon ui-white-icon" src="/images/icons/create.png" mode="aspectFit"/>
      <text>{{joining ? '加入中...' : '加入行程'}}</text>
  </view>
</view>
