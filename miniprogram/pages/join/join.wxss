/* 加入行程 · 日落暖色调 */

.join-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
}

.join-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.join-title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  background: var(--gradient-sunset);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.join-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.6;
}

.code-box {
  margin-bottom: 48rpx;
}

.code-input {
  width: 100%;
  height: 110rpx;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 12rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  line-height: 62rpx;
}

.code-input:focus {
  border-color: var(--coral);
}

/* 覆盖默认按钮为日落渐变 */
.join-page .btn-primary {
  background: var(--gradient-sunset);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
}
