/* 加入行程 · 拾途蓝 */

.join-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
}

.join-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}

.join-title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.join-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.6;
}

.code-box {
  margin-bottom: 48rpx;
}

.code-input {
  width: 100%;
  height: 110rpx;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 12rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  line-height: 62rpx;
}

.code-input:focus {
  border-color: var(--trip-blue);
}

/* 覆盖默认按钮为拾途蓝渐变 */
.join-page .btn-primary {
  background: var(--gradient-trip);
  box-shadow: 0 6rpx 20rpx rgba(91, 159, 245, 0.35);
}

.scan-join-btn {
  margin-top: 22rpx;
  height: 86rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--trip-blue-deep);
  background: rgba(236, 245, 255, 0.96);
  border: 1rpx solid rgba(125, 185, 248, 0.22);
  font-size: 26rpx;
  font-weight: 850;
}

.scan-join-btn image {
  width: 34rpx;
  height: 34rpx;
}
