/* ═══════════════════════════════════════
   设置资料页
   ═══════════════════════════════════════ */

.setup-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f0f7ff 0%, #dbeafe 35%, #f5faff 70%, #ecf5ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 48rpx env(safe-area-inset-bottom);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰背景气泡 */
.bg-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.bg-blob-1 {
  width: 340rpx;
  height: 340rpx;
  background: radial-gradient(circle, rgba(91,159,245,0.12) 0%, transparent 70%);
  top: -60rpx;
  right: -80rpx;
  animation: blobFloat1 8s ease-in-out infinite;
}

.bg-blob-2 {
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(91,159,245,0.09) 0%, transparent 70%);
  bottom: 160rpx;
  left: -80rpx;
  animation: blobFloat2 10s ease-in-out infinite;
}

@keyframes blobFloat1 {
  0%, 100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(-20rpx, 30rpx) scale(1.06); }
}

@keyframes blobFloat2 {
  0%, 100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(25rpx, -20rpx) scale(1.08); }
}

.setup-body {
  width: 100%;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ═══════════════════════════════════════
   品牌区域
   ═══════════════════════════════════════ */

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.step-badge {
  font-size: 20rpx;
  color: #5b9ff5;
  background: rgba(91,159,245,0.10);
  padding: 6rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  letter-spacing: 6rpx;
  font-weight: 700;
}

.app-title {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #5b9ff5, #5b9ff5);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #7db9f8;
  letter-spacing: 4rpx;
}

/* ═══════════════════════════════════════
   表单卡片
   ═══════════════════════════════════════ */

.form-card {
  width: 100%;
  max-width: 520rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(91,159,245,0.08), 0 2rpx 8rpx rgba(0,0,0,0.03);
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

/* ═══════════════════════════════════════
   头像区域
   ═══════════════════════════════════════ */

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8rpx;
}

/* 圆形头像容器 + 透明按钮覆盖 */
.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  margin-bottom: 20rpx;
  box-shadow: 0 0 0 6rpx rgba(91,159,245,0.06), 0 8rpx 28rpx rgba(91,159,245,0.15);
}

.avatar-wrap:active {
  transform: scale(0.95);
  transition: transform 0.15s;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ecf5ff, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #cfe0f8;
  box-sizing: border-box;
}

.avatar-placeholder-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.40;
}

/* 透明按钮覆盖整个头像区域 */
.avatar-picker {
  position: absolute;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: transparent;
  opacity: 0;
  overflow: hidden;
}

.avatar-picker::after {
  border: none;
  border-radius: 50%;
}

.avatar-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-label {
  font-size: 24rpx;
  color: #7db9f8;
  letter-spacing: 2rpx;
}

/* ═══════════════════════════════════════
   分割线
   ═══════════════════════════════════════ */

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #dcecff, transparent);
  margin: 24rpx 0 28rpx 0;
}

/* ═══════════════════════════════════════
   昵称
   ═══════════════════════════════════════ */

.nick-section {
  position: relative;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.label-icon {
  width: 24rpx;
  height: 24rpx;
}

.nick-input {
  width: 100%;
  height: 84rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: #ecf5ff;
  border-radius: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.nick-input:focus {
  border-color: #b8cfeb;
  background: #fff;
}

.nick-input::placeholder {
  color: #cfe0f8;
  font-size: 26rpx;
}

.nick-counter {
  text-align: right;
  font-size: 20rpx;
  color: #b8cfeb;
  margin-top: 8rpx;
}

/* ═══════════════════════════════════════
   按钮区域
   ═══════════════════════════════════════ */

.action-section {
  width: 100%;
  max-width: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  background: var(--gradient-purple);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(91,159,245,0.40);
  padding: 0;
  margin-bottom: 24rpx;
  border: none;
  letter-spacing: 6rpx;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  transform: scale(0.97);
}

.confirm-btn[disabled] {
  opacity: 0.6;
}

.skip-link {
  font-size: 26rpx;
  color: #b8cfeb;
  padding: 20rpx;
  letter-spacing: 2rpx;
}
