/* 用户主页 */

.up-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.up-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.up-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.up-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5e0ff, #ecccff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--purple);
  font-weight: 600;
  flex-shrink: 0;
}

.up-info {
  flex: 1;
}

.up-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e1e2e;
  margin-bottom: 10rpx;
}

.up-stats {
  display: flex;
  align-items: center;
}

.up-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e1e2e;
}

.up-stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 6rpx;
}

.up-follow-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  background: var(--gradient-purple);
  color: #fff;
}

.up-follow-btn.following {
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.up-moments-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

/* 动态卡片复用 */
.moment-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.mi-text {
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 12rpx;
  color: var(--text-primary);
}

.mi-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mi-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  background: var(--bg);
}

.mi-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mi-video {
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mi-video-play {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-video-dur {
  position: absolute;
  bottom: 4rpx;
  right: 6rpx;
  font-size: 20rpx;
  color: #a5b4fc;
  background: rgba(0,0,0,0.5);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.mi-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mi-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.mi-actions-sm {
  display: flex;
  gap: 20rpx;
}

.mi-as {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

.mi-as-icon {
  width: 24rpx;
  height: 24rpx;
}
