/* 用户主页 */

.up-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.up-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.up-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.up-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--purple);
  font-weight: 600;
  flex-shrink: 0;
}

.up-info {
  flex: 1;
}

.up-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e1e2e;
  margin-bottom: 8rpx;
}

.up-signature {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.up-stats {
  display: flex;
  align-items: center;
}

.up-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e1e2e;
}

.up-stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 6rpx;
}

.up-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.up-action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.up-follow-btn {
  background: var(--gradient-purple);
  color: #fff;
}

.up-follow-btn.following {
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.up-follow-btn.mutual {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #92400e;
  border: 2rpx solid #fcd34d;
}

.up-message-btn {
  background: #fff;
  color: var(--purple);
  border: 2rpx solid rgba(91, 159, 245, 0.28);
}

.up-moments-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

/* 动态卡片复用 */
.moment-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.mi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mi-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mi-avatar, .mi-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.mi-avatar-placeholder {
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--purple);
  font-weight: 600;
}

.mi-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mi-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mi-status-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.mi-text {
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.mi-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mi-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: var(--bg);
}

.mi-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.mi-video {
  width: 210rpx;
  height: 210rpx;
  border-radius: 10rpx;
  background: #1e1b4b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mi-video-play {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-video-play image {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

.mi-video-dur {
  position: absolute;
  bottom: 4rpx;
  right: 6rpx;
  font-size: 20rpx;
  color: #a5b4fc;
  background: rgba(0,0,0,0.5);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.mi-location {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.mi-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.mi-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  padding-top: 14rpx;
}

.mi-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 10rpx 14rpx;
}

.mi-action-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.mi-action-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e1e2e;
}

.mi-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.mi-comments {
  margin-top: 12rpx;
  padding: 14rpx 16rpx 0;
  border-top: 1rpx solid var(--border);
}

.cmt-item {
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.cmt-author {
  color: var(--purple);
  font-weight: 700;
  margin-right: 8rpx;
}

.cmt-text {
  color: var(--text-primary);
}
