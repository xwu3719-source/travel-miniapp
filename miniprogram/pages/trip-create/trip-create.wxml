<page-meta page-style="{{themeStyle}}"/>
<message-popup />
<!-- 创建/编辑行程 -->
<scroll-view scroll-y class="container page-scroll {{themeClass}}">
  <view class="form-title">{{isEdit ? '编辑行程' : (sourceLabel ? '复用行程' : '新建行程')}}</view>

  <view wx:if="{{!isEdit && sourceLabel}}" class="source-banner">
    <image src="/images/icons/history.png" mode="aspectFit"/>
    <view class="source-banner-copy">
      <view class="source-banner-title">{{sourceLabel}}</view>
      <view class="source-banner-subtitle">将复制日程、地点和备注，不复制成员、账本与动态</view>
    </view>
    <view class="source-banner-clear" bindtap="onClearSource">清除</view>
  </view>

  <view wx:if="{{!isEdit && templates.length}}" class="template-section">
    <view class="template-section-head">
      <view>
        <view class="template-section-title">我的模板</view>
        <view class="template-section-subtitle">选择一个常用结构快速开始</view>
      </view>
    </view>
    <scroll-view scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" class="template-scroll">
      <view
        wx:for="{{templates}}"
        wx:key="_id"
        class="template-card {{templateId === item._id ? 'active' : ''}}"
        data-id="{{item._id}}"
        bindtap="onTemplateTap"
        bindlongpress="onTemplateLongPress"
      >
        <image src="/images/icons/archive.png" mode="aspectFit"/>
        <view class="template-card-name">{{item.name}}</view>
        <view class="template-card-meta">{{item.city || '多目的地'}} · {{item.totalDays}}天 · {{item.activityCount}}项</view>
      </view>
    </scroll-view>
  </view>

  <!-- 行程名称 -->
  <view class="form-group">
    <view class="form-label">行程名称</view>
    <input class="form-input" placeholder="{{nameFocus ? '' : '例如：日本关西赏枫之旅'}}" value="{{name}}" bindinput="onNameInput" bindfocus="onNameFocus" bindblur="onNameBlur" maxlength="30"/>
  </view>

  <!-- 目的地 -->
  <view class="form-group">
    <view class="form-label">目的地</view>
    <input class="form-input" placeholder="{{cityFocus ? '' : '例如：大阪 · 京都 · 奈良'}}" value="{{city}}" bindinput="onCityInput" bindfocus="onCityFocus" bindblur="onCityBlur" maxlength="30"/>
  </view>

  <!-- 日期 -->
  <view class="form-group">
    <view class="form-label">出行日期</view>
    <view class="date-row">
      <picker mode="date" value="{{startDate}}" start="2024-01-01" end="2030-12-31" bindchange="onStartDateChange">
        <view class="date-box">
          <image class="date-box-icon" src="/images/icons/date.png" mode="aspectFit"/>
          <text wx:if="{{startDate}}">{{startDate}}</text>
          <text wx:else class="placeholder">开始日期</text>
        </view>
      </picker>
      <text class="date-sep">→</text>
      <picker mode="date" value="{{endDate}}" start="2024-01-01" end="2030-12-31" bindchange="onEndDateChange">
        <view class="date-box">
          <image class="date-box-icon" src="/images/icons/date.png" mode="aspectFit"/>
          <text wx:if="{{endDate}}">{{endDate}}</text>
          <text wx:else class="placeholder">结束日期</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 总预算 -->
  <view class="form-group">
    <view class="form-label">总预算（可选）</view>
    <view class="budget-input-row">
      <text class="budget-prefix">¥</text>
      <input class="form-input budget-input" type="digit" placeholder="{{budgetFocus ? '' : '0'}}" value="{{totalBudget}}" bindinput="onBudgetInput" bindfocus="onBudgetFocus" bindblur="onBudgetBlur"/>
    </view>
  </view>

  <!-- 分类预算 -->
  <view class="form-group">
    <view class="form-label-row" bindtap="toggleCategoryBudget">
      <view class="form-label">分类预算（可选）</view>
      <view class="toggle-arrow {{showCategoryBudget ? 'open' : ''}}">›</view>
    </view>
    <block wx:if="{{showCategoryBudget}}">
      <view class="cat-grid">
        <view class="cat-item" wx:for="{{categories}}" wx:key="key">
          <view class="cat-label">
            <image class="cat-label-icon" src="{{item.icon}}" mode="aspectFit"/>
            <text>{{item.label}}</text>
          </view>
          <input class="form-input cat-input" type="digit" placeholder="0" value="{{categoryBudgets[item.key]}}" data-cat="{{item.key}}" bindinput="onCatBudgetInput"/>
        </view>
      </view>
    </block>
  </view>

  <!-- 保存 -->
  <view class="btn btn-primary btn-block" bindtap="onSave">
    <image wx:if="{{!saving}}" class="save-action-icon" src="/images/icons/create.png" mode="aspectFit"/>
    <text>{{saving ? '保存中...' : (isEdit ? '更新行程' : '创建行程')}}</text>
  </view>
</scroll-view>
