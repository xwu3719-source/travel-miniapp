/* 创建/编辑行程 · 日落暖调 */

.form-title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 36rpx;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.source-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(91,159,245,0.2);
  border-radius: 22rpx;
  background: var(--gradient-trip-soft);
}
.source-banner > image { width: 40rpx; height: 40rpx; flex-shrink: 0; }
.source-banner-copy { flex: 1; min-width: 0; }
.source-banner-title { color: var(--text-primary); font-size: 25rpx; font-weight: 750; }
.source-banner-subtitle { margin-top: 5rpx; color: var(--text-hint); font-size: 20rpx; line-height: 1.45; }
.source-banner-clear { flex-shrink: 0; color: var(--trip-blue-deep); font-size: 22rpx; }

.template-section { margin-bottom: 30rpx; }
.template-section-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 14rpx; }
.template-section-title { color: var(--text-primary); font-size: 27rpx; font-weight: 750; }
.template-section-subtitle { margin-top: 4rpx; color: var(--text-hint); font-size: 21rpx; }
.template-scroll { width: 100%; white-space: nowrap; }
.template-card {
  display: inline-flex;
  width: 280rpx;
  min-height: 146rpx;
  margin-right: 14rpx;
  padding: 20rpx;
  flex-direction: column;
  justify-content: center;
  vertical-align: top;
  border: 1rpx solid rgba(91,159,245,0.12);
  border-radius: 22rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}
.template-card.active { border-color: rgba(91,159,245,0.52); background: var(--gradient-trip-soft); }
.template-card > image { width: 34rpx; height: 34rpx; margin-bottom: 10rpx; }
.template-card-name { overflow: hidden; color: var(--text-primary); font-size: 25rpx; font-weight: 750; text-overflow: ellipsis; white-space: nowrap; }
.template-card-meta { margin-top: 6rpx; overflow: hidden; color: var(--text-hint); font-size: 20rpx; text-overflow: ellipsis; white-space: nowrap; }

/* ══════ 输入框聚焦 ══════ */
.form-group input:focus {
  background: var(--card-bg);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.form-group:nth-child(2) .form-input:focus,
.form-group:nth-child(3) .form-input:focus { border-color: var(--trip-blue); }

/* ══════ 日期选择 ══════ */
.date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-row picker {
  flex: 1;
}

.date-box {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

.date-box-icon {
  width: 26rpx;
  height: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.date-sep {
  font-size: 32rpx;
  color: var(--trip-blue-deep);
  font-weight: 600;
}

/* ══════ 预算 ══════ */
.budget-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

.budget-input-row:focus-within {
  border-color: var(--trip-blue);
  background: var(--card-bg);
}

.budget-prefix {
  font-size: 36rpx;
  font-weight: 700;
  background: var(--gradient-trip);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.budget-input {
  flex: 1;
  background: transparent !important;
  border: none !important;
  padding: 24rpx 0 !important;
  height: auto !important;
}

/* ══════ 分类预算 ══════ */
.form-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  transition: transform 0.25s;
}

.toggle-arrow.open {
  transform: rotate(90deg);
}

.cat-grid {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cat-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 8rpx 20rpx;
  border-left: 6rpx solid;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.cat-item { border-left-color: var(--trip-blue); }

.cat-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  min-width: 140rpx;
}

.cat-label-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.cat-input {
  flex: 1;
  background: var(--bg) !important;
  border: 2rpx solid transparent !important;
  padding: 16rpx 20rpx !important;
  height: auto !important;
}

.cat-input:focus {
  border-color: var(--trip-blue) !important;
  background: var(--card-bg) !important;
}

/* ══════ 按钮 ══════ */
.btn-primary {
  background: var(--gradient-trip) !important;
  box-shadow: 0 6rpx 20rpx rgba(91, 159, 245, 0.28) !important;
}

.btn-block {
  margin-top: 48rpx;
  margin-bottom: 40rpx;
}

.save-action-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
  filter: brightness(0) invert(1);
  flex-shrink: 0;
}
