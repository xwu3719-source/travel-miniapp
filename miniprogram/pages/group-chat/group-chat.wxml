<page-meta page-style="{{themeStyle}}"/>
<message-popup />
<view class="group-chat-page {{themeClass}}">
  <!-- 顶栏 -->
  <view class="group-top-bar">
    <view class="group-avatar-grid" style="{{groupAvatarStyle}}">
      <block wx:for="{{memberAvatars}}" wx:key="index">
        <image wx:if="{{item.url}}" src="{{item.url}}" class="group-avatar-cell" mode="aspectFill"/>
        <view wx:else class="group-avatar-cell placeholder" style="background:{{item.color}};">{{item.initial}}</view>
      </block>
    </view>
    <view class="group-top-info">
      <view class="group-top-name">{{group.name || '群聊'}}</view>
      <view class="group-top-count">{{members.length}} 位成员</view>
    </view>
    <view class="group-top-more" catchtap="onToggleMore">
      <text class="group-top-more-icon">···</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view scroll-y class="chat-list {{showTools || showEmoji ? 'panel-open' : ''}} {{replyingTo ? 'reply-open' : ''}}" style="{{chatListPaddingStyle}}" scroll-into-view="{{scrollIntoView}}" scroll-top="{{scrollTop}}" show-scrollbar="{{false}}" enhanced="{{true}}">
    <view wx:if="{{loading}}" class="chat-empty">加载中...</view>
    <view wx:elif="{{messages.length === 0}}" class="chat-empty">群聊已创建，打个招呼吧</view>

    <view wx:for="{{messages}}" wx:key="_id" id="group-message-{{index}}" class="chat-row {{item.isMine ? 'mine' : 'theirs'}}">
      <image wx:if="{{!item.isMine && item.senderAvatar}}" src="{{item.senderAvatar}}" class="sender-avatar" mode="aspectFill"/>
      <view wx:elif="{{!item.isMine}}" class="sender-avatar-placeholder">{{item.senderName[0] || '?'}}</view>

      <view class="chat-bubble-wrap" data-index="{{index}}" bindlongpress="onMessageLongPress">
        <view wx:if="{{!item.isMine}}" class="sender-name-row">
          <text class="sender-name-text">{{item.senderName}}</text>
          <image wx:if="{{item.senderVerified}}" class="sender-verified-icon" src="/images/icons/官方认证.png" mode="aspectFit"/>
          <image wx:if="{{item.senderBadgeIcon}}" class="sender-badge-icon" src="/images/icons/{{item.senderBadgeIcon}}" mode="aspectFit"/>
        </view>

        <view class="chat-time">{{item.formattedTime}}</view>

        <view wx:if="{{item.quoteMessageId && item.type !== 'revoked'}}" class="message-quote" data-message-id="{{item.quoteMessageId}}" catchtap="onOpenQuotedMessage">
          <view class="message-quote-name">{{item.quoteDisplayName}}</view>
          <view class="message-quote-text">{{item.quoteText}}</view>
        </view>

        <view wx:if="{{item.type === 'revoked'}}" class="message-revoked">{{item.isMine ? '你撤回了一条消息' : (item.senderName || '成员') + '撤回了一条消息'}}</view>
        <image wx:elif="{{item.type === 'image'}}" class="chat-image-message" src="{{item.imageFileId}}" mode="aspectFill" lazy-load="{{true}}" data-url="{{item.imageFileId}}" bindtap="onOpenMessageImage"/>
        <view wx:elif="{{item.type === 'voice'}}" class="voice-message {{voicePlayingId === item._id ? 'playing' : ''}}" style="width: {{item.voiceBubbleWidth || 176}}rpx" data-message-id="{{item._id}}" data-url="{{item.voiceFileId}}" catchtap="onPlayVoiceMessage">
          <image class="voice-message-icon" src="/images/icons/chat-voice.png" mode="aspectFit"/>
          <view wx:if="{{voicePlayingId === item._id}}" class="voice-wave"><view></view><view></view><view></view></view>
          <text class="voice-duration">{{item.voiceDuration || 1}}″</text>
        </view>
        <view wx:elif="{{item.type === 'location'}}" class="rich-card location-card" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-name="{{item.locationName}}" bindtap="onOpenMessageLocation">
          <image class="rich-card-icon" src="/images/icons/location.png" mode="aspectFit"/>
          <view class="rich-card-copy"><view class="rich-card-title">{{item.locationName}}</view><view class="rich-card-subtitle">{{item.locationAddress || '点击查看位置'}}</view></view>
        </view>
        <view wx:elif="{{item.type === 'file'}}" class="rich-card" data-file-id="{{item.fileId}}" data-file-name="{{item.fileName}}" data-file-type="{{item.fileType}}" bindtap="onOpenMessageFile">
          <image class="rich-card-icon" src="/images/icons/profile-archive.png" mode="aspectFit"/>
          <view class="rich-card-copy"><view class="rich-card-title">{{item.fileName}}</view><view class="rich-card-subtitle">点击打开文件</view></view>
        </view>
        <view wx:elif="{{item.type === 'user_card'}}" class="rich-card" data-openid="{{item.cardOpenid}}" bindtap="onOpenUserCard">
          <image wx:if="{{item.cardAvatar}}" class="card-avatar" src="{{item.cardAvatar}}" mode="aspectFill"/>
          <view wx:else class="card-avatar placeholder">{{item.cardName[0] || '?'}}</view>
          <view class="rich-card-copy"><view class="rich-card-title">{{item.cardName}}</view><view class="rich-card-subtitle">ID {{item.cardPublicId}}</view></view>
        </view>
        <view wx:elif="{{item.type === 'moment_share'}}" class="moment-share-card" data-moment-id="{{item.momentId}}" bindtap="onOpenSharedMoment">
          <image wx:if="{{item.momentImage}}" class="moment-share-image" src="{{item.momentImage}}" mode="aspectFill"/>
          <view wx:else class="moment-share-placeholder"><image src="/images/icons/tab-moments.png" mode="aspectFit"/></view>
          <view class="moment-share-copy">
            <view class="moment-share-kicker">动态分享</view>
            <view class="moment-share-title">{{item.momentText || '分享了一条旅行动态'}}</view>
            <view class="moment-share-author">来自 {{item.momentAuthorName || '旅友'}}</view>
          </view>
        </view>
        <view wx:else class="chat-bubble">{{item.text}}</view>
      </view>

      <image wx:if="{{item.isMine && myAvatarUrl}}" src="{{myAvatarUrl}}" class="my-avatar" mode="aspectFill"/>
      <view wx:elif="{{item.isMine}}" class="my-avatar-placeholder">{{myNickName[0] || '我'}}</view>
    </view>
  </scroll-view>

  <!-- 录音浮层 -->
  <view wx:if="{{recording}}" class="recording-overlay {{recordCanceling ? 'canceling' : ''}}">
    <image src="/images/icons/chat-voice.png" mode="aspectFit"/>
    <view class="recording-time">{{recordingDuration}}″</view>
    <view class="recording-tip">{{recordCanceling ? '松开取消发送' : '松开发送，上滑取消'}}</view>
  </view>

  <!-- 更多面板 -->
  <view wx:if="{{showMore}}" class="more-overlay" catchtap="onCloseMore">
    <view class="more-panel" catchtap="preventBubble">
      <view class="more-title">群聊信息</view>

      <!-- 成员列表 -->
      <view class="more-section">
        <view class="more-section-title">群成员 ({{members.length}})</view>
        <scroll-view scroll-y class="more-member-list">
          <view wx:for="{{members}}" wx:key="openid" class="more-member-row">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="more-member-avatar" mode="aspectFill"/>
            <view wx:else class="more-member-avatar placeholder">{{item.nickName[0] || '?'}}</view>
            <view class="more-member-info">
              <view class="more-member-name">
                {{item.nickName || '成员'}}
                <text wx:if="{{item.role === 'owner'}}" class="more-tag owner">群主</text>
                <text wx:if="{{item.openid === myOpenid}}" class="more-tag me">我</text>
                <text wx:if="{{item.muted}}" class="more-tag muted">已禁言</text>
              </view>
            </view>
            <view wx:if="{{myRole === 'owner' && item.openid !== myOpenid}}" class="more-member-action" data-openid="{{item.openid}}" data-muted="{{item.muted}}" catchtap="{{item.muted ? 'onUnmuteMember' : 'onMuteMember'}}">{{item.muted ? '解除' : '禁言'}}</view>
          </view>
        </scroll-view>
      </view>

      <!-- 消息免打扰 -->
      <view class="more-section">
        <view class="more-row" catchtap="onToggleNotifications">
          <text>消息免打扰</text>
          <switch checked="{{notificationsMuted}}" color="#5b9ff5"/>
        </view>
        <view class="more-row" catchtap="onOpenMedia">
          <text>聊天文件</text>
          <image class="more-row-arrow" src="/images/icons/chevron-right.png" mode="aspectFit" />
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="more-actions">
        <view class="more-btn" catchtap="onLeaveGroup">退出群聊</view>
        <view wx:if="{{myRole === 'owner'}}" class="more-btn danger" catchtap="onDissolveGroup">解散群聊</view>
      </view>

      <view class="more-close" catchtap="onCloseMore">关闭</view>
    </view>
  </view>

  <!-- 输入栏 -->
  <view class="chat-input-bar" style="bottom: {{keyboardHeight}}px;">
    <view wx:if="{{replyingTo}}" class="reply-composer">
      <view class="reply-composer-copy">
        <view class="reply-composer-name">回复 {{replyingTo.senderName}}</view>
        <view class="reply-composer-text">{{replyingTo.text}}</view>
      </view>
      <view class="reply-composer-cancel" bindtap="onCancelReply">取消</view>
    </view>
    <view class="chat-input-row">
      <view class="chat-icon-button {{voiceMode ? 'active' : ''}}" bindtap="onToggleVoiceMode">
        <image src="/images/icons/chat-voice.png" mode="aspectFit"/>
      </view>
      <input wx:if="{{!voiceMode}}" class="chat-input" value="{{inputText}}" maxlength="500" confirm-type="send" adjust-position="{{false}}" placeholder="发消息" bindkeyboardheightchange="onKeyboardHeightChange" bindinput="onInput" bindconfirm="onSend"/>
      <view wx:else class="hold-to-talk {{recording ? 'recording' : ''}} {{recordCanceling ? 'canceling' : ''}}" bindtouchstart="onVoiceTouchStart" bindtouchmove="onVoiceTouchMove" bindtouchend="onVoiceTouchEnd" bindtouchcancel="onVoiceTouchCancel">{{recording ? (recordCanceling ? '松开取消' : '松开发送') : '按住 说话'}}</view>
      <view class="chat-icon-button {{showEmoji ? 'active' : ''}}" bindtap="onToggleEmoji">
        <image src="/images/icons/chat-emoji.png" mode="aspectFit"/>
      </view>
      <view class="chat-invite {{showTools ? 'active' : ''}}" bindtap="onToggleTools">+</view>
    </view>

    <view wx:if="{{showTools}}" class="chat-tools">
      <view class="chat-tool" bindtap="onSendImage"><image src="/images/icons/image.png" mode="aspectFit"/><text>图片</text></view>
      <view class="chat-tool" bindtap="onCameraCapture"><image src="/images/icons/chat-camera.png" mode="aspectFit"/><text>拍摄</text></view>
      <view class="chat-tool" bindtap="onSendLocation"><image src="/images/icons/location.png" mode="aspectFit"/><text>位置</text></view>
      <view class="chat-tool" bindtap="onSendFile"><image src="/images/icons/profile-archive.png" mode="aspectFit"/><text>文件</text></view>
      <view class="chat-tool" bindtap="onSendCard"><image src="/images/icons/trip-members.png" mode="aspectFit"/><text>名片</text></view>
    </view>

    <view wx:if="{{showEmoji}}" class="emoji-panel">
      <view wx:for="{{emojiList}}" wx:key="*this" class="emoji-item" data-emoji="{{item}}" bindtap="onSelectEmoji">{{item}}</view>
    </view>
  </view>
</view>
