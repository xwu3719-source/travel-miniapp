/* 动态详情 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0;
}

.page-scroll {
  position: relative;
}

.content-scroll {
  flex: 1;
  height: 0;
  padding: 24rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 固定底部评论栏 */
.cmt-bar-fixed {
  flex-shrink: 0;
  padding: 0 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border);
}

/* 头部 */
.md-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.md-author {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.md-avatar, .md-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.md-avatar-placeholder {
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--purple);
  font-weight: 600;
}

.md-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #000;
}

.md-name-row {
  display: flex;
  align-items: center;
  gap: 9rpx;
}

.md-verified-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.md-badge-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.md-status-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.md-time {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 文字 */
.md-text {
  font-size: 32rpx;
  line-height: 1.8;
  margin-bottom: 24rpx;
  color: var(--text-primary);
}

/* 图片 */
.md-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.md-img {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
  background: var(--bg);
}

.md-videos {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.md-video {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
  background: #1e1b4b;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.md-video-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.md-video-play {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.md-video-play image {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

.md-video-dur {
  font-size: 24rpx;
  color: #a5b4fc;
}

/* 地点 */
.md-location {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.md-loc-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

/* 互动栏 */
.md-actions {
  display: flex;
  gap: 40rpx;
  padding: 20rpx 0;
}

.md-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: var(--icon-touch);
  padding: 0 10rpx;
  box-sizing: border-box;
}

.md-action-icon {
  font-size: 32rpx;
}

.md-action-icon-img {
  width: var(--icon-sm);
  height: var(--icon-sm);
  opacity: var(--icon-muted-opacity);
}

.md-action.liked .md-action-icon-img,
.md-action.favorited .md-action-icon-img { opacity: var(--icon-active-opacity); }

.md-action-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e1e2e;
}

.md-action.liked .md-action-icon {
  color: var(--rose);
}

.md-action.favorited .md-action-icon {
  color: var(--amber);
}

/* 作者管理菜单 */
.md-more {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #e5e7eb;
}

.md-more:active {
  background: #d1d5db;
}

.md-more-icon {
  font-size: 32rpx;
  color: #374151;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1;
}

.md-menu {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 20;
  overflow: hidden;
  min-width: 220rpx;
}

.md-menu-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  white-space: nowrap;
}

.md-menu-item:active {
  background: var(--bg);
}

.md-menu-item.danger {
  color: var(--red);
}

/* 评论区 */
.md-comments {
  margin-top: 28rpx;
}

.md-comments-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.cmt-list {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.cmt-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  font-size: 30rpx;
  line-height: 1.7;
  padding: 18rpx 0;
}

.cmt-item.cmt-divider {
  border-bottom: 1rpx solid var(--border);
}

/* 评论头像 */
.cmt-avatar,
.cmt-avatar-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.cmt-avatar-placeholder {
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.cmt-edited-tag {
  font-size: 20rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.cmt-body {
  flex: 1;
  min-width: 0;
}

.cmt-header {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex-wrap: wrap;
}

.cmt-author {
  color: #000;
  font-weight: 600;
  flex-shrink: 0;
}

.cmt-reply-mark {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.cmt-text {
  color: var(--text-primary);
  font-size: 30rpx;
  margin-top: 4rpx;
}

.cmt-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  display: block;
}

.cmt-empty {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 32rpx 0;
}

/* 评论语音 */
.cmt-voice {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.cmt-voice-icon {
  font-size: 24rpx;
}

.cmt-voice-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.cmt-voice.voice-playing {
  background: rgba(91, 159, 245, 0.12);
}
.voice-bars {
  display: inline-flex;
  gap: 3rpx;
  align-items: flex-end;
  height: 22rpx;
}
.voice-bar {
  width: 5rpx;
  border-radius: 3rpx;
  background: var(--purple);
  animation: voiceBarAnim 0.45s ease-in-out infinite alternate;
}
.voice-bar:nth-child(2) { animation-delay: 0.12s; }
.voice-bar:nth-child(3) { animation-delay: 0.24s; }
@keyframes voiceBarAnim {
  from { height: 6rpx; }
  to { height: 22rpx; }
}
.cmt-voice-dur {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 评论位置 */
.cmt-location {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--teal);
  padding: 4rpx 10rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 8rpx;
}

.cmt-loc-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* 评论媒体预览 */
.cmt-media-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cmp-item {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.cmp-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.cmp-voice-item {
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.cmp-voice-icon {
  font-size: 28rpx;
}

.cmp-voice-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.cmp-voice-dur {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.cmp-loc-item {
  gap: 4rpx;
  padding: 8rpx 14rpx;
  background: rgba(16, 185, 129, 0.06);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--teal);
}

.cmp-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cmp-remove image {
  width: 18rpx;
  height: 18rpx;
  filter: brightness(0) invert(1);
}

.cmt-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

.cmt-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg);
  border-radius: 36rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.cmt-tool-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.cmt-tool-icon {
  width: 34rpx;
  height: 34rpx;
}

.cmt-tool-btn.recording {
  background: #fef2f2;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 录音状态条 */
.recording-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  border: 2rpx solid #fecaca;
  margin-bottom: 12rpx;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: recPulse 0.8s infinite;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.rec-text {
  flex: 1;
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 600;
}

.rec-time {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.rec-stop {
  font-size: 24rpx;
  color: #fff;
  background: #ef4444;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* 点赞者列表 */
.md-likers {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 4rpx;
}

.md-likers-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.md-likers-avatars {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.md-liker-avatar,
.md-liker-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  flex-shrink: 0;
}

.md-liker-avatar.overlap,
.md-liker-avatar-placeholder.overlap {
  margin-left: -12rpx;
}

.md-liker-avatar-placeholder {
  background: linear-gradient(135deg, #dbeafe, #93c5fd);
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.md-likers-suffix {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.cmt-cancel-edit {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
  padding: 0 8rpx;
}

.cmt-send {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--purple);
  padding: 0 16rpx;
  flex-shrink: 0;
}
