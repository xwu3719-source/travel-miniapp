.message-popup-safe {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10000;
  padding: calc(env(safe-area-inset-top) + 14rpx) 24rpx 0;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-120%);
  transition: opacity .22s ease, transform .32s cubic-bezier(.2,.8,.2,1);
}

.message-popup-safe.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.message-popup {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding: 18rpx 18rpx 18rpx 20rpx;
  border: 1rpx solid rgba(164, 203, 246, .42);
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(241,248,255,.92));
  box-shadow: 0 16rpx 48rpx rgba(50, 105, 170, .16), inset 0 1rpx 0 rgba(255,255,255,.9);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.message-avatar-wrap { position: relative; flex: none; width: 68rpx; height: 68rpx; margin-right: 18rpx; }
.message-avatar, .message-avatar-fallback { width: 68rpx; height: 68rpx; border-radius: 22rpx; }
.message-avatar { background: #eaf3ff; }
.message-avatar-fallback {
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; font-weight: 750;
  background: linear-gradient(135deg, #79b7f8, #a7d1fb);
}
.message-kind-dot {
  position: absolute; right: -7rpx; bottom: -6rpx;
  width: 30rpx; height: 30rpx; border: 3rpx solid #fff; border-radius: 50%;
  color: #fff; background: #6ba8ee; font-size: 16rpx; line-height: 30rpx; text-align: center;
}
.message-copy { flex: 1; min-width: 0; }
.message-heading { display: flex; align-items: center; gap: 12rpx; margin-bottom: 5rpx; }
.message-title { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #17233b; font-size: 27rpx; font-weight: 750; }
.message-time { flex: none; color: #9aa9bc; font-size: 19rpx; }
.message-preview { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #718096; font-size: 23rpx; }
.message-close {
  flex: none; width: 56rpx; height: 56rpx; margin-left: 8rpx;
  display: flex; align-items: center; justify-content: center;
}
.message-close image { width: 28rpx; height: 28rpx; opacity: .46; }
